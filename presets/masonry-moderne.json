[
    {
        "id": "masonry-hero",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "grid",
            "gridTemplateColumns": "2fr 1fr",
            "gridTemplateRows": "auto auto",
            "gap": "1.5rem",
            "padding": "2rem",
            "backgroundColor": "#fafaf9",
            "minHeight": "70vh"
        },
        "children": [
            {
                "id": "hero-main-image",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "height": "100%",
                    "objectFit": "cover",
                    "borderRadius": "16px",
                    "gridRow": "span 2",
                    "boxShadow": "0 12px 40px rgba(0,0,0,0.1)"
                }
            },
            {
                "id": "hero-side-image-1",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "aspectRatio": "1/1",
                    "objectFit": "cover",
                    "borderRadius": "12px",
                    "boxShadow": "0 8px 24px rgba(0,0,0,0.08)"
                }
            },
            {
                "id": "hero-artist-card",
                "type": "container",
                "style": {
                    "display": "flex",
                    "flexDirection": "column",
                    "justifyContent": "center",
                    "padding": "2rem",
                    "backgroundColor": "#292524",
                    "borderRadius": "12px",
                    "gap": "1rem"
                },
                "children": [
                    {
                        "id": "artist-name-masonry",
                        "type": "artistName",
                        "content": "",
                        "style": {
                            "fontSize": "1.75rem",
                            "fontWeight": "600",
                            "color": "#fafaf9"
                        }
                    },
                    {
                        "id": "artist-bio-short",
                        "type": "artistBio",
                        "content": "",
                        "style": {
                            "fontSize": "0.95rem",
                            "color": "#a8a29e",
                            "lineHeight": "1.6"
                        }
                    }
                ]
            }
        ]
    },
    {
        "id": "masonry-gallery",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "grid",
            "gridTemplateColumns": "1fr 1fr 1fr",
            "gridAutoRows": "minmax(200px, auto)",
            "gap": "1rem",
            "padding": "2rem",
            "backgroundColor": "#ffffff"
        },
        "children": [
            {
                "id": "gallery-img-tall",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "height": "100%",
                    "objectFit": "cover",
                    "borderRadius": "8px",
                    "gridRow": "span 2"
                }
            },
            {
                "id": "gallery-img-2",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "aspectRatio": "1/1",
                    "objectFit": "cover",
                    "borderRadius": "8px"
                }
            },
            {
                "id": "gallery-img-3",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "aspectRatio": "1/1",
                    "objectFit": "cover",
                    "borderRadius": "8px"
                }
            },
            {
                "id": "gallery-quote",
                "type": "text",
                "content": "<blockquote style='font-style: italic; color: #57534e;'>\"L'art est le reflet de l'âme\"</blockquote>",
                "style": {
                    "display": "flex",
                    "alignItems": "center",
                    "justifyContent": "center",
                    "padding": "2rem",
                    "backgroundColor": "#f5f5f4",
                    "borderRadius": "8px",
                    "fontSize": "1.25rem"
                }
            },
            {
                "id": "gallery-img-4",
                "type": "image",
                "content": "",
                "style": {
                    "width": "100%",
                    "aspectRatio": "16/9",
                    "objectFit": "cover",
                    "borderRadius": "8px",
                    "gridColumn": "span 2"
                }
            }
        ]
    },
    {
        "id": "masonry-footer",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "flex",
            "flexDirection": "row",
            "alignItems": "center",
            "justifyContent": "space-between",
            "padding": "3rem 4rem",
            "backgroundColor": "#1c1917",
            "gap": "2rem"
        },
        "children": [
            {
                "id": "footer-photo",
                "type": "artistPhoto",
                "content": "",
                "style": {
                    "width": "80px",
                    "height": "80px",
                    "borderRadius": "50%",
                    "objectFit": "cover",
                    "border": "3px solid #78716c"
                }
            },
            {
                "id": "footer-text",
                "type": "text",
                "content": "<p>Œuvres disponibles à la vente • Commandes personnalisées acceptées</p>",
                "style": {
                    "color": "#d6d3d1",
                    "fontSize": "1rem",
                    "flex": "1"
                }
            }
        ]
    }
]