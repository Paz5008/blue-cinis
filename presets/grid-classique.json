[
    {
        "id": "grid-header",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "flex",
            "flexDirection": "column",
            "alignItems": "center",
            "padding": "4rem 2rem",
            "backgroundColor": "#f8fafc",
            "gap": "1.5rem"
        },
        "children": [
            {
                "id": "artist-name-centered",
                "type": "artistName",
                "content": "",
