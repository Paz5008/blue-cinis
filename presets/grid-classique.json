    {
        "id": "grid-artist-section",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "flex",
            "flexDirection": "row",
            "alignItems": "center",
            "gap": "3rem",
            "padding": "4rem",
            "backgroundColor": "#f1f5f9"
        },
        "children": [
            {
                "id": "artist-photo-round",
                "type": "artistPhoto",
                "content": "",
                "style": {
                    "width": "200px",
                    "height": "200px",
                    "borderRadius": "50%",
                    "objectFit": "cover",
                    "boxShadow": "0 8px 30px rgba(0,0,0,0.12)"
                }
            },
            {
                "id": "artist-statement",
                "type": "text",
                "content": "<p>Découvrez mon univers artistique, mes inspirations et mon processus créatif. Chaque œuvre raconte une histoire unique.</p>",
                "style": {
                    "fontSize": "1.125rem",
                    "color": "#475569",
                    "lineHeight": "1.8",
                    "flex": "1"
                }
            }
        ]
    },
    {
        "id": "grid-cta",
        "type": "container",
        "style": {
            "position": "relative",
            "display": "flex",
            "justifyContent": "center",
            "padding": "3rem 2rem",
            "backgroundColor": "#0f172a"
        },
        "children": [
            {
                "id": "cta-text",
                "type": "text",
                "content": "<p style='color: white; font-size: 1.5rem;'>Contactez-moi pour une commande personnalisée</p>",
                "style": {
                    "color": "#ffffff",
                    "textAlign": "center"
                }
            }
        ]
