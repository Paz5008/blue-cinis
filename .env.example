# --- BASE & URLS ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require&schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require&schema=public"
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require&schema=shadow_prisma"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
DOMAIN="http://localhost:3000"
NEXTAUTH_SECRET="please-change-me-to-a-strong-secret"
ALLOW_ANONYMOUS_CANVAS_PREVIEW=0

# --- EMAILS & ANTI-SPAM ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SALES_EMAIL=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- STRIPE / PAYMENTS ---
PAYMENTS_PROVIDER=stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENABLE_TAX=false
STRIPE_PM_TYPES=card,sepa_debit
STRIPE_SHIPPING_RATES=
STRIPE_SHIPPING_COUNTRIES=FR,BE,DE,ES,IT,NL,LU,CH,GB

# --- NEWSLETTER ---
NEWSLETTER_PROVIDER=brevo
BREVO_API_KEY=
BREVO_LIST_ID=

# --- RATE LIMITING / MFA ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- MÉDIAS & UPLOADS ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=uploads
CLOUDINARY_AUTHENTICATED=false
CLOUDINARY_SIGNED_TTL=300
IMAGE_DOMAINS="res.cloudinary.com,images.unsplash.com,i.imgur.com"

# --- ANALYTICS & OBSERVABILITÉ ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SRC=

# --- CRON & DIVERS ---
CRON_CLEANUP_SECRET=
ADMIN_OVERRIDE_EMAILS="artist@example.com"
ADMIN_MFA_BYPASS=0
ENABLE_DEV_AUTO_USER=0
PRISMA_MOCK=0
