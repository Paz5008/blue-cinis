const BlockInspector = dynamic(() => import('./BlockInspector'), { loading: () => <div className="p-4 text-xs text-neutral-500">Chargement de l'inspecteur...</div> });
const EditorUnifiedMenu = dynamic(() => import('./EditorUnifiedMenu'), { loading: () => <div className="h-14 w-full bg-neutral-100 animate-pulse" /> });

const ArtworkCreateModal = dynamic(() => import('./ArtworkCreateModal'), { ssr: false });

const BannerOptimizePanel = dynamic(() => import('./banner/BannerOptimizePanel').then(mod => mod.BannerOptimizePanel), { loading: () => <div className="p-4 text-xs text-neutral-500">Chargement...</div> });
const BannerTemplateDrawer = dynamic(() => import('./banner/BannerTemplateDrawer').then(mod => mod.BannerTemplateDrawer), { loading: () => <div className="p-4 text-xs text-neutral-500">Chargement des modèles...</div> });
const PageTemplateSelector = dynamic(() => import('./controls/PageTemplateSelector').then(mod => mod.PageTemplateSelector), { ssr: false });
import { useEditorBanner, BANNER_DESIGN_WIDTH, BANNER_DESIGN_HEIGHT, BANNER_DESIGN_HEIGHT_MOBILE } from './editor/useEditorBanner';
