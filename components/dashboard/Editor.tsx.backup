import { useDraggable, useDroppable, DndContext, DragOverlay, closestCenter, pointerWithin, rectIntersection, KeyboardSensor, PointerSensor, useSensor, useSensors, DragStartEvent, DragEndEvent, TouchSensor, MouseSensor, MeasuringStrategy } from '@dnd-kit/core';
import { SortableContext, arrayMove, verticalListSortingStrategy, rectSortingStrategy, useSortable } from '@dnd-kit/sortable';
import { restrictToVerticalAxis } from '@dnd-kit/modifiers';
import { CSS } from '@dnd-kit/utilities';
import type { BlockType, Block, ThemeConfig, TextBlock, ImageBlock, EmbedBlock, ButtonBlock, GalleryImage, ContainerBlock, ColumnBlock, GalleryBlock } from '../../types/cms';
import { resolveThemeTokens, type ThemeTokens } from '@/lib/cms/themeTokens';
import { buildHoverCSS } from '@/lib/cms/css-generator';
import { buildEmbedUrl } from '@/lib/cms/embed';
import { sanitizeTextHtml } from '@/lib/sanitize';
import { normalizeCmsUrl, type NormalizeCmsUrlOptions } from '@/lib/url';
import { getContrastRatio } from '@/lib/colors';
import { EditorPalette } from './editor/EditorPalette';
import {

  PaletteView,
  EditorMode,
  OeuvreOption,
  PublishWarning,
  DragMeta,
