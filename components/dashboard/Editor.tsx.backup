import { usePreviewSync } from './editor/hooks/usePreviewSync';
import { useBlockOperations } from './editor/hooks/useBlockOperations';
import { createBlockInstance } from './editor/EditorUtils';
import { EditableTextBlock } from './editor/EditableTextBlock';
import { EditorActionsContext, EditorStateContext, type EditorContextType, type EditorState, type EditorActions } from './editor/EditorContext';

import { useEditorAccessibility } from './editor/useEditorAccessibility';
import { getTemplateByKey } from '@/lib/cms/templates';
import { moveRootBlock } from '@/lib/dnd-strategies/root';

const buildSectionBlocks = (section: any) => { return [] as any[]; };
const handlePreviewSection = (family: any, section: any) => { };
const addQuickSection = (sectionKey: any) => { };
const openBannerTemplateDrawerStub = (opts: any) => { };
const closeQuickSectionsModal = () => { };

import { moveContainerChild, moveContainerChildToRoot, insertRootIntoContainer } from '@/lib/dnd-strategies/container';
import { moveBlockIntoColumns } from '@/lib/dnd-strategies/columns';
import { DropActionContext } from '@/lib/dnd-strategies/types';
import { extractAtmosphere, getTextColorForBackground } from '@/lib/atmosphere';
import { iconMap } from './editor/constants';
import { useEditorDragDrop } from './editor/hooks/useEditorDragDrop';
import { useCanvasInteraction } from './hooks/useCanvasInteraction';
import { useBeforeUnload } from './editor/hooks/useBeforeUnload';
import { computeWrapperStyle, resolveFontFamily, checklistFromBlocks } from './editor/EditorHelpers';
import type { CategoryOption, ArtworkPayload } from './ArtworkCreateForm';
// import BlockButton from './BlockButton';
import { saveArtistPageLayout } from '@/actions/save-layout';



interface ColumnDroppableProps extends React.HTMLAttributes<HTMLDivElement> {
  droppableId: string;
}

const ColumnDroppable: React.FC<ColumnDroppableProps> = ({ droppableId, className = '', children, ...rest }) => {
  const { isOver, setNodeRef } = useDroppable({ id: droppableId });
  const classes = [className, isOver ? 'ring-2 ring-blue-400/60 ring-offset-2 ring-offset-blue-50' : '']
    .filter(Boolean)
    .join(' ');
  return (
    <div ref={setNodeRef} className={classes} {...rest}>
      {children}
    </div>
  );
};

const CONTAINER_COLUMN_DROPPABLE_PREFIX = 'container-column:';


export default function Editor({
  initialContent,
  oeuvreOptions: initialOeuvreOptions = [],
  artistData,
  previewUrl,
  initialPublicationStatus = 'draft',
  pageKey,
  artistHasStripe = false,
  artistEnableCommerce = true,
  bannerInsights: initialBannerInsights = null,
  pageNavigation = [],
  lastPublishedAt = null,
  artworkCategories = [],
  initialArtworkModalOpen = false,
}: EditorProps) {
  const { addToast } = useToast();
  const filteredFamilies: any[] = []; // Mock to fix build
  const recommendedFamilyKey = null; // Mock to fix build
  // Initialize blocks from initialContent or empty
  // Initialisation du contenu et du thème
  const init = initialContent || {};
  const normalizedPageKey = (pageKey || 'profile').toLowerCase();
  const currentPage: EditorPageKey =
    normalizedPageKey === 'poster' || normalizedPageKey === 'banner' ? (normalizedPageKey as EditorPageKey) : 'profile';
  const isPoster = currentPage === 'poster';
  const isBanner = currentPage === 'banner';

  const defaultTheme: ThemeConfig = {
    primaryColor: '#1e3a8a',
    secondaryColor: '#4f46e5',
    backgroundColor: '#ffffff',
    textColor: '#000000',
    headingFont: 'sans-serif',
    bodyFont: 'sans-serif',
    layout: 'default',
    backgroundImageUrl: undefined,
    coverImageUrl: undefined,
  };

  const initialMetaState = {
    title: (init.meta?.title as string) || '',
    description: (init.meta?.description as string) || '',
    canonicalUrl: (init.meta?.canonicalUrl as string) || '',
  };

  // Aperçu device (desktop/mobile) moved up for hook dependency
  const [device, setDevice] = useState<'desktop' | 'mobile'>('desktop');
  // ARIA live regions
  const [liveStatus, setLiveStatus] = useState<string>('');
  const [selectedIndex, setSelectedIndex] = useState<number | null>(null);
  const [selectedChild, setSelectedChild] = useState<{ parentId: string; childId: string } | null>(null);
  const [nextFocusBlockId, setNextFocusBlockId] = useState<string | null>(null);

  // Lock body scroll to prevent pull-to-refresh and nested scrolling on mobile editor
  useEffect(() => {
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';
    return () => {
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
    };
  }, []);

  // Constants restored (Design System)
  const mobilePreviewWidth = 375;
  const posterDesignWidth = 800;
  const posterDesignHeight = 1130;
  const posterDesignHeightMobile = 600;

  // Stubs for missing variables

  const initialSettings: any = {};
  const textContrastRatio: number | null = 4.5;
  const overlayContrastRatio: number | null = 3.0;
  const bannerDesktopShellWidthCss = 'min(100%, 1200px)';
  const desktopMaxWidth = 1200;

  // Theme apply state (restored)
  const [applyThemeToHome, setApplyThemeToHome] = useState(false);

  // Customization endpoint logic
  const customizationEndpoint = React.useMemo(() => {
    return isBanner ? '/api/artist/banner/customize' : '/api/artist/customization';
  }, [isBanner]);

  const {
    blocks, // Derived array (device-specific)
    blocksData,
    desktopLayout,
    setBlocksData,
    setDesktopLayout,
    reorderBlocks,
    suspendHistoryRef,
    theme,
    setTheme,
    meta,
    setMeta,
    isDirty: dirty,
    setDirty,
    undo,
    redo,
    canUndo,
    canRedo,
    resetHistory,

    addBlock,
    removeBlock,
    setBlocks,
    duplicateBlock,
    updateBlock,
    moveBlock,
    replaceContent,
  } = useEditorBlocks({
    initialContent: init as any, // Cast for migration support
    initialTheme: init.theme || defaultTheme,
    initialMeta: initialMetaState,
    isBanner,
    setSelectedIndex,
    setSelectedChild,
    setNextFocusBlockId,
    setLiveStatus,
    addToast,
  });



  const themeTokens = React.useMemo(() => resolveThemeTokens(theme), [theme]);

  // MOVED STATE TO TOP
  const [viewMode, setViewMode] = useState<'edit' | 'theme' | 'preview'>('edit');
  const [previewSyncEnabled, setPreviewSyncEnabled] = useState(true);
  const blockRefs = useRef<Record<string, HTMLDivElement | null>>({});
  const [isCanvasDragOver, setIsCanvasDragOver] = useState(false);
  const [canvasWidth, setCanvasWidth] = useState<number | undefined>(undefined);

  // Preview sync hook (only active when viewMode === 'preview' and enabled)
  const previewSync = usePreviewSync(
    blocks,
    theme,
    previewSyncEnabled && viewMode === 'preview' ? 300 : 0 // Disable sync when not in preview mode
  );
  const effectiveBlocks = (previewSyncEnabled && viewMode === 'preview') ? previewSync.blocks : blocks;
  const effectiveTheme = (previewSyncEnabled && viewMode === 'preview') ? previewSync.theme : theme;


  // HELPERS MOVED TO TOP
  // Bibliothèque d'uploads partagée (public/uploads)
  const uploadsRef = useRef<string[]>([]);
  useEffect(() => {
    fetch('/api/uploads').then(r => r.ok ? r.json() : Promise.reject()).then(d => {
      const arr = Array.isArray(d?.media) ? d.media.map((m: any) => m.url) : [];
      uploadsRef.current = arr;
    }).catch(() => { });
  }, []);
  const pickUpload = React.useCallback((seed: number): string | undefined => {
    const arr = uploadsRef.current;
    if (!arr || arr.length === 0) return undefined;
    const index = Math.abs(seed) % arr.length;
    return arr[index];
  }, []);

  const manifestRef = useRef<any>(null);
  useEffect(() => {
    fetch('/uploads/manifest.json').then(r => r.ok ? r.json() : Promise.resolve({})).then(data => { manifestRef.current = data || {}; }).catch(() => { });
  }, []);
  const getHeroBg = React.useCallback((presetKey: string): string | undefined => {
    const m = manifestRef.current;
    const fromManifest = m && m.hero && typeof m.hero[presetKey] === 'string' && m.hero[presetKey] ? m.hero[presetKey] : undefined;
    if (fromManifest) return fromManifest;
    const curated: Record<string, string> = {
      signature: '/hero-background3.avif',
      editorialPro: '/hero-background.avif',
      minimalClean: '/hero-background.avif',
      showcaseDeluxe: '/hero-background2.avif',
      portfolioMasonry: '/hero-background2.avif',
      boutique: '/hero-background.avif',
      default: '/hero-background.avif',
    };
    return curated[presetKey] || curated.default || pickUpload(0);
  }, [pickUpload]);
  const getLoremImages = React.useCallback((count: number = 8, seed: number = 0) => {
    const arr = uploadsRef.current || [];
    if (!arr || arr.length === 0) return [];
    const total = Math.min(count, Math.max(4, arr.length));
    return Array.from({ length: total }, (_, i) => ({
      id: crypto.randomUUID(),
      src: arr[(seed + i) % arr.length],
      alt: '',
    }));
  }, []);

  const allBlocks = React.useMemo<BlockType[]>(() => [
    'text', 'image', 'gallery', 'video', 'embed', 'divider', 'quote', 'columns', 'button', 'container', 'spacer', 'oeuvre', 'artworkList', 'artistName', 'artistPhoto', 'artistBio', 'contactForm', 'eventList',
  ], []);
  const getAllowedBlocks = React.useCallback((k?: string): BlockType[] => {
    switch ((k || 'profile').toLowerCase()) {
      case 'banner': return ['text', 'image', 'button', 'spacer', 'container'];
      case 'poster': return ['text', 'image', 'gallery', 'embed', 'divider', 'spacer', 'container', 'artistName', 'artistPhoto', 'artistBio', 'oeuvre', 'artworkList', 'eventList'];
      default: return allBlocks;
    }
  }, [allBlocks]);
  const blockTypes: BlockType[] = React.useMemo(() => getAllowedBlocks(pageKey), [getAllowedBlocks, pageKey]);

  // RESTORED STATE
  const [mounted, setMounted] = useState(false);
  const [showTutorial, setShowTutorial] = useState(false);
  const [paletteView, setPaletteView] = useState<PaletteView>(() => (isBanner ? 'sections' : 'blocks'));
  const [showPalette, setShowPalette] = useState(true);
  const [showInspector, setShowInspector] = useState(true);
  const [paletteQuery, setPaletteQuery] = useState('');
  const inspectorVisible = viewMode === 'edit' && showInspector;
  const inspectorPaneActive = inspectorVisible;
  const focusModeActive = !showPalette && !showInspector;
  const sanitizeRichText = React.useCallback(
    (value: string) => sanitizeTextHtml(value || '', (pageKey || 'profile') as any),
    [pageKey]
  );
  useEffect(() => { setMounted(true); }, []);
  useEffect(() => {
    if (!isBanner) return;
    if (paletteView === 'guides' && !showPalette) {
      setShowPalette(true);
    }
  }, [isBanner, paletteView, showPalette]);

  // RESTORED UI STATE
  const [showMoreMenu, setShowMoreMenu] = useState(false);
  const [quickSectionFilter, setQuickSectionFilter] = useState<QuickSectionFilter>('all');
  const [expandedQuickFamily, setExpandedQuickFamily] = useState<string | null>(null);

  const [debugOutlines, setDebugOutlines] = useState(false);
  const [isFocusMode, setIsFocusMode] = useState(false);
  const fileInputRef = useRef<HTMLInputElement | null>(null);

  const [showFeaturedPicker, setShowFeaturedPicker] = useState(false);
  const [postInsertChecklist, setPostInsertChecklist] = useState<{ sectionKey: string; label: string; steps: string[]; accentColor?: string } | null>(null);
  const [featuredSelection, setFeaturedSelection] = useState<string[]>([]);
  const toggleFeatured = (id: string) => setFeaturedSelection(prev => { const set = new Set(prev); if (set.has(id)) set.delete(id); else if (set.size < 2) set.add(id); return Array.from(set); });
  const upsertFeaturedAfterHero = (ids: string[]) => {
    if (!ids || ids.length === 0) return;
    setBlocks(prev => {
      const arr = [...prev];
      const insertAt = arr.length > 0 ? 1 : 0;
      // Try to find existing featuredHeader block
      const idx = arr.findIndex(b => (b as any).type === 'oeuvre' && (b as any).purpose === 'featuredHeader');
      const makeBlock = () => { const ob: any = createBlockInstance('oeuvre'); ob.purpose = 'featuredHeader'; ob.artworks = ids; ob.layout = 'grid'; ob.columns = Math.min(2, ids.length); ob.gap = 16; ob.showTitle = true; ob.showArtist = true; ob.showPrice = false; ob.showYear = false; ob.style = { margin: '1rem auto', maxWidth: '900px' }; return ob; }
      if (idx >= 0) { const ob = arr[idx] as any; ob.artworks = ids; ob.columns = Math.min(2, ids.length); arr[idx] = ob as any; } else { arr.splice(insertAt, 0, makeBlock() as any); }
      return arr;
    });
  };

  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  const openThemeTuning = useCallback(() => {
    // setViewMode('theme');
    // setShowPalette(true);
  }, []);
  const [showThemeModal, setShowThemeModal] = useState(false);
  const closeThemeModal = useCallback(() => {
    setShowThemeModal(false);
    if (viewMode === 'theme') {
      setViewMode('edit');
    }
  }, [viewMode]);

  const [recentBlocks, setRecentBlocks] = useState<BlockType[]>([]);
  useEffect(() => {
    try {
      const raw = window.localStorage.getItem('cmsRecentBlocks');
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return;
      const filtered = (parsed as BlockType[]).filter(type => (blockTypes as BlockType[]).includes(type));
      setRecentBlocks(prev => {
        if (filtered.length === prev.length && filtered.every((t, idx) => t === prev[idx])) return prev;
        return filtered;
      });
    } catch { }
  }, [blockTypes]);
  useEffect(() => {
    setRecentBlocks(prev => {
      const filtered = prev.filter(type => blockTypes.includes(type));
      if (filtered.length === prev.length && filtered.every((t, idx) => t === prev[idx])) return prev;
      return filtered;
    });
  }, [blockTypes]);
  useEffect(() => {
    if (!mounted) return;
    try { window.localStorage.setItem('cmsRecentBlocks', JSON.stringify(recentBlocks)); } catch { }
  }, [recentBlocks, mounted]);

  const rememberBlock = useCallback((type: BlockType) => {
    if (!blockTypes.includes(type)) return;
    setRecentBlocks(prev => {
      const next = [type, ...prev.filter(t => t !== type)];
      return next.slice(0, 6);
    });
  }, [blockTypes]);

  // --- HOOKS ---
  const {
    handleAddBlock,
    addBlockAt,
    handleAddStructuralBlock,
    updateBlockAtIndex,
    convertBlock,
  } = useBlockOperations({
    blocks,
    setBlocks,
    addBlock,
    removeBlock,
    duplicateBlock,
    updateBlock,
    setSelectedIndex,
    setNextFocusBlockId,
    setLiveStatus,
    setMeta,
    artistData,
    isBanner,
    rememberBlock,
    setPostInsertChecklist,
    theme,
    oeuvreOptions: initialOeuvreOptions,
    getHeroBg,
    pickUpload,
    getLoremImages,
  });

  const {
    sensors,
    activeDragType,
    handleDndKitDragStart,
    handleDndKitDragEnd,
    handleDragStart,
    handleDrop,
    startAbsDrag
  } = useEditorDragDrop({
    blocks,
    setBlocks,
    addBlockAt,
    setDirty,
    setSelectedIndex,
    setSelectedChild,
    setLiveStatus,
    blockRefs,
    setIsCanvasDragOver,
    viewMode
  });

  const quickTitlePlaceholder = React.useMemo(() => {
    const baseName = typeof artistData?.name === 'string' ? artistData.name.trim() : '';
    if (isBanner) return baseName ? `${baseName} - Bandeau` : 'Bandeau artiste - Blue Cinis';
    if (isPoster) return baseName ? `${baseName} - Affiche` : 'Affiche artiste - Blue Cinis';
    return baseName ? `${baseName} - Profil` : 'Profil artiste - Blue Cinis';
  }, [artistData?.name, isBanner, isPoster]);

  const [liveAssertive, setLiveAssertive] = useState<string>('');

  // Presets de mise en page
  const applyTemplate = useCallback((newBlocks: Block[]) => {
    // Utilise replaceContent pour une mise à jour atomique de l'historique
    replaceContent({
      blocks: newBlocks,
      theme, // Conserve le thème actuel
      meta,  // Conserve les métadonnées actuelles
    });
    addToast('Modèle appliqué avec succès', 'success');
  }, [replaceContent, theme, meta, addToast]);

  const [showTemplateSelector, setShowTemplateSelector] = useState(false);
  const handleSelectTemplate = useCallback((newBlocks: Block[], newTheme?: Partial<ThemeConfig>) => {
    if (newTheme) {
      replaceContent({
        blocks: newBlocks,
        theme: { ...theme, ...newTheme } as ThemeConfig,
        meta,
      });
      addToast('Modèle et thème appliqués', 'success');
    } else {
      applyTemplate(newBlocks);
    }
    setShowTemplateSelector(false);
  }, [applyTemplate, theme, meta, replaceContent, addToast]);

  const [publicationStatus, setPublicationStatus] = useState<'draft' | 'published'>(initialPublicationStatus);
  const [saving, setSaving] = useState(false);
  const [, setLastSavedAt] = useState<Date | null>(null);
  const [autoSaving, setAutoSaving] = useState(false);
  const [, setLastAutoSavedAt] = useState<Date | null>(null);
  const [isFreeForm, setIsFreeForm] = useState(true); // Default to "Antigravity" mode






  // Presets de mise en page

  useEffect(() => {
    if (selectedIndex === null) return;
    if (selectedIndex < 0 || selectedIndex >= blocks.length) {
      setSelectedIndex(null);
    }
  }, [selectedIndex, blocks.length]);

  const {
    bannerContentRef,
    showBannerGuides,
    setShowBannerGuides,
    bannerCoach,
    bannerInsights,
    bannerInsightsLoading,
    refreshBannerInsights,
    bannerCanvasDiagnostics,
    bannerSafeWindowStyle,
    formatRelativeTime,

  } = useBannerExperience({
    isBanner,
    blocks,
    theme,
    applyThemeToHome,
    addToast,
    initialBannerInsights,
    bannerDesignHeight: BANNER_DESIGN_HEIGHT,
    bannerDesignWidth: BANNER_DESIGN_WIDTH,
  });

  const bannerOverflow = bannerCanvasDiagnostics?.overflow ?? 0;

  useEffect(() => {
    if (!isBanner) return;
    const shouldShowGuides = bannerOverflow > 0;
    setShowBannerGuides(prev => (prev === shouldShowGuides ? prev : shouldShowGuides));
  }, [isBanner, bannerOverflow, setShowBannerGuides]);






  // État local pour la pagination des blocs artworkList: par blockId
  const [artworkListState] = useState<Record<string, { page?: number; shown?: number }>>({});
  const getALState = (id: string) => artworkListState[id] || {};

  const [tutorialStep, setTutorialStep] = useState(0);
  const modeRef = useRef<HTMLButtonElement | null>(null);
  const deviceRef = useRef<HTMLButtonElement | null>(null);


  const saveRef = useRef<HTMLButtonElement | null>(null);
  const publishRef = useRef<HTMLButtonElement | null>(null);

  const paletteRef = useRef<HTMLDivElement | null>(null);
  const presetRef = useRef<HTMLButtonElement | null>(null);
  const paletteSearchInputRef = useRef<HTMLInputElement | null>(null);
  const inspectorRef = useRef<HTMLDivElement | null>(null);

  // Canvas width for user resizing
  const canvasRef = useRef<HTMLDivElement>(null);
  const mainScrollRef = useRef<HTMLDivElement>(null);
  const canvasContentRef = useRef<HTMLDivElement | null>(null);
  const [canvasMetrics, setCanvasMetrics] = useState<{ scrollWidth: number; clientWidth: number; scrollHeight: number; clientHeight: number }>({
    scrollWidth: 0,
    clientWidth: 0,
    scrollHeight: 0,
    clientHeight: 0,
  });
  const [dimensionErrors, setDimensionErrors] = useState<string[]>([]);
  const hasDimensionError = dimensionErrors.length > 0;
  const canvasFrameClassName = React.useMemo(() => {
    if (!(isPoster || isBanner)) return 'relative mx-auto h-full';
    if (isBanner) {
      const errorRing = hasDimensionError ? 'ring-2 ring-red-500/60' : '';
      return [
        'relative mx-auto w-full max-w-[1280px] rounded-[32px] overflow-hidden',
        errorRing,
      ]
        .filter(Boolean)
        .join(' ')
        .trim();
    }
    const borderClass = hasDimensionError
      ? 'border-red-500/50 ring-2 ring-red-500/20'
      : '';
    return `relative mx-auto rounded-xl ${borderClass} overflow-hidden shadow-sm`;
  }, [hasDimensionError, isBanner, isPoster]);

  const canvasMainClassName = React.useMemo(() => {
    if (device === 'mobile') {
      if (isBanner) {
        return [
          'w-full mx-auto overflow-visible bg-transparent p-0 transition-transform duration-500 ease-out', // Let FreeFormCanvas handle width
          isCanvasDragOver ? 'scale-[1.02]' : '',
        ]
          .filter(Boolean)
          .join(' ')
          .trim();
      }
      return [
        `${isPoster ? '' : 'resize-x '}w-[390px] mx-auto overflow-auto rounded-[40px] border-[8px] border-neutral-900 bg-white shadow-2xl transition-all duration-500 ease-out`,
        isCanvasDragOver ? 'ring-4 ring-blue-500/50 scale-[1.01]' : 'ring-1 ring-white/10 ring-offset-0',
        'scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-transparent',
      ]
        .filter(Boolean)
        .join(' ')
        .trim();
    }
    if (isBanner) {
      return [
        'flex-1 w-full max-w-[1280px] mx-auto overflow-visible rounded-[36px] bg-transparent p-0 transition-all duration-500 ease-out supports-[backdrop-filter]:bg-transparent',
        isCanvasDragOver ? 'ring-2 ring-blue-400/70 scale-[1.005]' : '',
      ]
        .filter(Boolean)
        .join(' ')
        .trim();
    }
    return [
      `${isPoster ? '' : 'resize-x '}flex-1 w-full mx-auto overflow-auto rounded-3xl border border-white/10 bg-white/5 p-7 shadow-2xl backdrop-blur-2xl transition-all duration-500 ease-out`,
      isCanvasDragOver ? 'ring-2 ring-blue-500/50 scale-[1.005]' : 'ring-1 ring-white/5',
      'scrollbar-thin scrollbar-thumb-white/20 scrollbar-track-transparent',
    ]
      .filter(Boolean)
      .join(' ')
      .trim();
  }, [device, isBanner, isPoster, isCanvasDragOver]);
  const showBannerInfoPill = isBanner && blocks.length === 0;
  const bannerLeadSectionClass = isBanner
    ? ['px-1', (blocks.length === 0 || hasDimensionError) ? 'mb-4' : ''].filter(Boolean).join(' ')
    : 'mt-3';
  const canvasFormatLabelDesktop = React.useMemo(() => {
    if (isBanner) return `${BANNER_DESIGN_WIDTH} × ${BANNER_DESIGN_HEIGHT} px`;
    if (isPoster) return `${posterDesignWidth} × ${posterDesignHeight} px`;
    return null;
  }, [isBanner, isPoster, BANNER_DESIGN_WIDTH, BANNER_DESIGN_HEIGHT, posterDesignWidth, posterDesignHeight]);
  const canvasFormatLabelMobile = React.useMemo(() => {
    if (isBanner) return `${mobilePreviewWidth} × ${BANNER_DESIGN_HEIGHT_MOBILE} px`;
    if (isPoster) return `${mobilePreviewWidth} × ${posterDesignHeightMobile} px`;
