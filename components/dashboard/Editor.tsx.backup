      {
        key: 'seo',
        label: 'SEO complété',
        ok: hasSeo,
        hint: 'Renseignez un titre et une description pour votre page publique.',
      },
    ];

    const completed = items.filter(item => item.ok).length;
    const score = items.length > 0 ? Math.round((completed / items.length) * 100) : 0;
    return { score, items };
  }, [blocks, isBanner, meta?.description, meta?.title]);





  const focusSeoInputs = () => {
    try {
      const el = document.getElementById('meta-title');
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        (el as HTMLInputElement).focus();
      }
    } catch { }
  };

  const checklistFromBlocks = (blocksToInspect: Block[]): string[] => {
    const steps = new Set<string>();
    const visit = (block: Block) => {
      const type = block.type;
      switch (type) {
        case 'text':
        case 'quote':
          steps.add('Adapter les textes à votre univers');
          break;
        case 'image':
        case 'gallery':
        case 'artistPhoto':
          steps.add('Remplacer les visuels par vos propres images');
          break;
        case 'button':
          steps.add('Mettre à jour le libellé et le lien du bouton');
          break;
        case 'oeuvre':
        case 'artworkList':
          steps.add('Sélectionner vos œuvres ou séries à mettre en avant');
          break;
        case 'contactForm':
          steps.add('Vérifier vos informations de contact');
          break;
        case 'eventList':
          steps.add('Actualiser vos événements et disponibilités');
          break;
      }
      const children = (block as any).children as Block[] | undefined;
      if (Array.isArray(children)) children.forEach((child: Block) => visit(child));
      const columns = (block as any).columns as Block[][] | undefined;
      if (Array.isArray(columns)) columns.forEach((col: Block[]) => col?.forEach(visit));
    };
    blocksToInspect.forEach(visit);
    return Array.from(steps);
  };






  const {
    isBannerTemplateDrawerOpen,
    bannerTemplateDraft,
    bannerTemplateSelection,
    bannerTemplateHasSelection,
    openBannerTemplateDrawer,
    closeBannerTemplateDrawer,
    toggleBannerTemplateBlock,
    selectAllBannerTemplateBlocks,
    clearBannerTemplateSelection,
    applyBannerTemplate,
    mergeBannerTemplate,
  } = useEditorBanner({
    isBanner,
  });

  const findBlockById = useCallback((items: Block[], blockId: string): Block | null => {
    for (const blk of items) {
      if (blk.id === blockId) return blk;
      const children = (blk as any)?.children as Block[] | undefined;
      if (Array.isArray(children)) {
        const found = findBlockById(children, blockId);
        if (found) return found;
      }
      const columns = (blk as any)?.columns as Block[][] | undefined;
      if (Array.isArray(columns)) {
        for (const col of columns) {
          const found = findBlockById(col, blockId);
          if (found) return found;
        }
      }
    }
    return null;
  }, []);

  const replaceBlockInTree = useCallback((
    items: Block[],
    blockId: string,
    replacer: (current: Block) => Block
  ): { blocks: Block[]; changed: boolean } => {
    let changed = false;
    const next = items.map(block => {
      let current = block;
      if ((block as any)?.id === blockId) {
        const replaced = replacer(block);
        if (replaced !== block) {
          changed = true;
          current = replaced;
        }
        return current;
      }

      let localChanged = false;

      const children = (block as any)?.children;
      if (Array.isArray(children) && children.length > 0) {
        const result = replaceBlockInTree(children, blockId, replacer);
        if (result.changed) {
          current = { ...(current as any), children: result.blocks } as Block;
          localChanged = true;
        }
      }

      const columns = (block as any)?.columns;
      if (Array.isArray(columns) && columns.length > 0) {
        let columnsChanged = false;
        const nextColumns = columns.map((col: Block[]) => {
          const result = replaceBlockInTree(col, blockId, replacer);
          if (result.changed) {
            columnsChanged = true;
            return result.blocks;
          }
          return col;
        });
        if (columnsChanged) {
          current = { ...(current as any), columns: nextColumns } as Block;
          localChanged = true;
        }
      }

      if (localChanged) changed = true;
      return current;
    });
    return { blocks: next, changed };
  }, []);

  const updateBlockById = useCallback((blockId: string, updater: (current: Block) => Block) => {
    if (!blockId) return;
    let didChange = false;
    setBlocks(prev => {
      const { blocks: next, changed } = replaceBlockInTree(prev, blockId, updater);
      didChange = changed;
      return changed ? next : prev;
    });
    if (didChange) {
      setDirty(true);
    }
  }, [replaceBlockInTree]);

  // État pour sélection d'un bloc enfant, qu'il soit dans colonnes ou container (columnIndex=-1 pour containers)

  useEffect(() => {
    if (selectedChild === null) return;
    const { parentId, childId } = selectedChild;
    const parent = findBlockById(blocks, parentId) as any;
    if (!parent) {
      setSelectedChild(null);
      return;
    }
    let child: Block | undefined;
    if (parent.type === 'container') {
      child = parent.children?.find((c: any) => c.id === childId);
    } else if (parent.type === 'columns') {
      for (const col of (parent.columns || [])) {
        if (!Array.isArray(col)) continue;
        const found = col.find((c: any) => c.id === childId);
        if (found) { child = found; break; }
      }
    }
    if (!child) {
      setSelectedChild(null);
    }
  }, [selectedChild, blocks, findBlockById]);






  /**
   * Ajoute un bloc enfant dans une colonne spécifique d'un ColumnBlock
   */
  /**
   * Ajoute un bloc enfant dans une colonne spécifique d'un ColumnBlock
   */
  const addBlockToColumn = (parentIndex: number, colIndex: number, type: BlockType) => {
    rememberBlock(type);
    const child = createBlockInstance(type);
    setBlocks(prev => prev.map((b, i) => {
      if (i === parentIndex && b.type === 'columns') {
        const colBlock = b as any;
        const newCols = colBlock.columns.map((col: Block[], idx: number) => (
          idx === colIndex ? [...col, child] : col
        ));
        return { ...colBlock, columns: newCols };
      }
      return b;
    }));
  };
  /**
   * Ajoute un bloc enfant dans un conteneur SectionBlock
   */
  const addBlockToContainer = (parentIndex: number, type: BlockType) => {
    rememberBlock(type);
    const child = createBlockInstance(type);
    setBlocks(prev => prev.map((b, i) => {
      if (i === parentIndex && b.type === 'container') {
        const cont = b as any;
        return { ...cont, children: [...cont.children, child] };
      }
      return b;
    }));
  };
  /**
   * Supprime un bloc enfant d'un conteneur SectionBlock
   */
  const removeBlockFromContainer = (parentIndex: number, parentId: string, childIndex: number) => {
    let updatedViaId = false;
    if (parentId) {
      updateBlockById(parentId, (parent: any) => {
        if (!parent || parent.type !== 'container' || !Array.isArray(parent.children)) return parent;
        if (childIndex < 0 || childIndex >= parent.children.length) return parent;
        updatedViaId = true;
        return { ...parent, children: parent.children.filter((_: any, idx: number) => idx !== childIndex) };
      });
    }
    if (!updatedViaId) {
      let mutated = false;
      setBlocks(prev => {
        const next = prev.map((b, i) => {
          if (i === parentIndex && (b as any)?.type === 'container') {
            const cont = b as any;
            if (!Array.isArray(cont.children)) return b;
            mutated = true;
            return { ...cont, children: cont.children.filter((_: any, idx: number) => idx !== childIndex) };
          }
          return b;
        });
        return mutated ? next : prev;
      });
      if (mutated) {
        setDirty(true);
      }
    }

  };

  const computeWrapperStyle = (b: Block): React.CSSProperties => {
    const st: any = { ...(b.style || {}) };
    if (st.position === 'absolute') {
      if (typeof st.top === 'number') st.top = `${st.top}px`;
      if (typeof st.left === 'number') st.left = `${st.left}px`;
      if (typeof st.right === 'number') st.right = `${st.right}px`;
      if (typeof st.bottom === 'number') st.bottom = `${st.bottom}px`;
      if (st.top == null && st.bottom == null) st.top = '8px';
      if (st.left == null && st.right == null) st.left = '8px';
      if (st.zIndex === undefined) st.zIndex = 1;
    }
    const align = b.style?.canvasAlign as 'left' | 'center' | 'right' | undefined;
    if (b.style?.width) {
      if (align === 'center') { st.marginLeft = 'auto'; st.marginRight = 'auto'; }
      else if (align === 'right') { st.marginLeft = 'auto'; st.marginRight = undefined; }
      else { st.marginLeft = undefined; st.marginRight = undefined; }
    }
    // Compose layered background: overlay, gradient, image
    const layers: string[] = [];
    if (typeof st.overlayColor === "string" && st.overlayColor) {
      const a = typeof st.overlayOpacity === "number" ? Math.max(0, Math.min(1, st.overlayOpacity)) : undefined;
      let color = st.overlayColor as string;
      if (a !== undefined && /^#/.test(color)) {
        const hex = color.replace('#', '');
        const bigint = parseInt(hex.length === 3 ? hex.split('').map((c: string) => c + c).join('') : hex, 16);
        const r = (bigint >> 16) & 255;
        const g = (bigint >> 8) & 255;
        const b2 = bigint & 255;
        color = `rgba(${r}, ${g}, ${b2}, ${a})`;
      } else if (a !== undefined && /^rgb\(/.test(color)) {
        // already rgba-compatible or rgb - ignoring alpha compose for simplicity
      }
      layers.push(`linear-gradient(${color}, ${color})`);
    }
    if (st.gradientFrom && st.gradientTo) {
      const dir = st.gradientDirection || "to bottom";
      const mid = st.gradientMid;
      if (st.gradientType === 'radial') {
        const stops = mid ? `${st.gradientFrom}, ${mid}, ${st.gradientTo}` : `${st.gradientFrom}, ${st.gradientTo}`;
        layers.push(`radial-gradient(circle at center, ${stops})`);
      } else {
        const stops = mid ? `${st.gradientFrom}, ${mid}, ${st.gradientTo}` : `${st.gradientFrom}, ${st.gradientTo}`;
        layers.push(`linear-gradient(${dir}, ${stops})`);
      }
    }
    if (st.backgroundImageUrl) {
      layers.push(`url(${st.backgroundImageUrl})`);
    }
    if (layers.length > 0) {
      st.backgroundImage = layers.join(', ');
      if (st.blendMode) st.backgroundBlendMode = st.blendMode;
      st.backgroundSize = st.backgroundImageUrl ? ((st.backgroundSize === 'custom' ? (st.backgroundSizeCustom || 'auto') : (st.backgroundSize || 'cover'))) : (st.backgroundSize || undefined);
      st.backgroundPosition = st.backgroundImageUrl ? ((st.backgroundPosition === 'custom' ? (st.backgroundPositionCustom || 'center') : (st.backgroundPosition || 'center'))) : (st.backgroundPosition || undefined);
      st.backgroundRepeat = st.backgroundImageUrl ? (st.backgroundRepeat || 'no-repeat') : (st.backgroundRepeat || undefined);
      if (st.parallax) st.backgroundAttachment = "fixed";
    }
    return st;
  };

  const resolveFontFamily = (name?: string): string | undefined => {
    if (!name) return undefined;
    const key = String(name).toLowerCase().trim();
    if (key === 'inter') return "var(--font-inter), Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif";
    if (key === 'poppins') return "var(--font-poppins), Poppins, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif";
    if (key === 'playfair display') return "var(--font-playfair), 'Playfair Display', Georgia, 'Times New Roman', serif";
    if (key === 'montserrat') return "var(--font-montserrat), Montserrat, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif";
    if (key === 'serif' || key === 'sans-serif' || key === 'monospace') return name;
    return name;
  };

  const coerceNumber = React.useCallback((value: unknown): number | undefined => {
    if (value === null || value === undefined) return undefined;
    if (typeof value === 'number' && Number.isFinite(value)) return value;
    const str = String(value).trim();
    if (!str) return undefined;
    const parsed = Number(str.replace(',', '.'));
    return Number.isFinite(parsed) ? parsed : undefined;
  }, []);

  const sanitizeBlocksForSave = React.useCallback((list: Block[]): Block[] => {
    const normalizeInteger = (value: unknown, opts: { fallback?: number; min?: number; max?: number } = {}) => {
      const { fallback, min, max } = opts;
      const num = coerceNumber(value);
      if (num === undefined || !Number.isFinite(num)) {
        return fallback;
      }
      let int = Math.round(num);
      if (!Number.isFinite(int)) {
        return fallback;
      }
      if (min !== undefined && int < min) int = min;
      if (max !== undefined && int > max) int = max;
      return int;
    };
    const setInt = (target: Record<string, unknown>, key: string, opts: { fallback: number; min?: number; max?: number }) => {
      if (!(key in target)) {
        target[key] = opts.fallback;
        return;
      }
      const normalized = normalizeInteger(target[key], opts);
      target[key] = normalized ?? opts.fallback;
    };
    const setOptionalInt = (target: Record<string, unknown>, key: string, opts: { fallback?: number; min?: number; max?: number }) => {
      if (!(key in target)) return;
      const normalized = normalizeInteger(target[key], opts);
      if (normalized === undefined) {
        if (opts.fallback === undefined) {
          delete target[key];
        } else {
          target[key] = opts.fallback;
        }
      } else {
        target[key] = normalized;
      }
    };
    const cleanUrl = (value: unknown, options?: NormalizeCmsUrlOptions) =>
      typeof value === 'string'
        ? normalizeCmsUrl(value, { allowRelative: true, allowData: true, allowMailto: true, ...(options || {}) })
        : undefined;

    const assignUrl = (target: any, key: string, options?: NormalizeCmsUrlOptions) => {
      if (!target || typeof target !== 'object' || !(key in target)) return;
      const safe = cleanUrl(target[key], options);
      if (safe) {
        target[key] = safe;
      } else {
        delete target[key];
      }
    };
    const sanitizeBlock = (block: Block): Block => {
      const cloned = { ...block };
      // Handle known recursive structures using specific types or type guards
      if (cloned.type === 'container') {
        const cont = cloned as any; // Fallback for container props not in base Block
        if (Array.isArray(cont.children)) {
          cont.children = cont.children.map((child: Block) => sanitizeBlock(child));
        }
        if ('columns' in cont && typeof cont.columns === 'number') {
          setInt(cont, 'columns', { fallback: 1, min: 1, max: 4 });
        }
        setOptionalInt(cont, 'columnsMobile', { fallback: cont.columns ?? 1, min: 1, max: 4 });
        setOptionalInt(cont, 'columnsTablet', { fallback: cont.columns ?? 1, min: 1, max: 4 });
        setOptionalInt(cont, 'columnsDesktop', { fallback: cont.columns ?? 1, min: 1, max: 4 });
      } else if (cloned.type === 'columns') {
        const colBlock = cloned as any;
        const columnsArray = Array.isArray(colBlock.columns)
          ? colBlock.columns.map((col: Block[]) => col.map((child: Block) => sanitizeBlock(child)))
          : [];
        const fallbackCount = columnsArray.length || 1;
        const count = normalizeInteger(colBlock.count, { fallback: fallbackCount, min: 1, max: 4 }) ?? fallbackCount;
        while (columnsArray.length > count) columnsArray.pop();
        while (columnsArray.length < count) columnsArray.push([]);
        colBlock.count = count;
        colBlock.columns = columnsArray;
        return colBlock;
      }

      // Generic Columns property on any block? Valid for some blocks.
      // We will cast to any for dynamic property checking to be safe but controlled
      const dynamicBlock = cloned as any;
      if (dynamicBlock.type !== 'columns' && Array.isArray(dynamicBlock.columns)) {
        dynamicBlock.columns = dynamicBlock.columns.map((col: Block[]) => col.map((child: Block) => sanitizeBlock(child)));
      }

      switch (cloned.type) {
        case 'image':
          assignUrl(cloned as any, 'src');
          break;
        case 'video':
          assignUrl(cloned as any, 'src', { allowData: false, allowRelative: false, allowMailto: false });
          assignUrl(cloned as any, 'poster');
          break;
        case 'button':
          assignUrl(cloned as any, 'url', { allowRelative: false });
          break;
        case 'embed':
          assignUrl(cloned as any, 'url', { allowRelative: false, allowMailto: false, allowData: false });
          assignUrl(cloned as any, 'thumbnailUrl');
          break;
        case 'gallery':
          if (Array.isArray(dynamicBlock.images)) {
            dynamicBlock.images = dynamicBlock.images.map((img: any) => {
              if (!img || typeof img !== 'object') return img;
              const next = { ...img };
              assignUrl(next, 'src');
              return next;
            });
          }
          setOptionalInt(dynamicBlock, 'columns', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columnsMobile', { fallback: 2, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columnsDesktop', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'gap', { fallback: 16, min: 0, max: 200 });
          break;
        case 'artworkList':
          assignUrl(cloned as any, 'cardBackgroundImageUrl');
          if (Array.isArray(dynamicBlock.selection)) {
            dynamicBlock.selection = dynamicBlock.selection.filter((id: unknown) => typeof id === 'string' && id.trim().length > 0);
          }
          if (dynamicBlock.query && typeof dynamicBlock.query === 'object') {
            const query = { ...dynamicBlock.query };
            query.priceMin = coerceNumber(query.priceMin);
            query.priceMax = coerceNumber(query.priceMax);
            query.yearMin = coerceNumber(query.yearMin);
            query.yearMax = coerceNumber(query.yearMax);
            if (!Array.isArray(query.categoryIds)) delete query.categoryIds;
            dynamicBlock.query = query;
          }
          setOptionalInt(dynamicBlock, 'columnsMobile', { fallback: 2, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columnsDesktop', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columns', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'gap', { fallback: 16, min: 0, max: 200 });
          setOptionalInt(dynamicBlock, 'limit', { fallback: 0, min: 0, max: 500 });
          setOptionalInt(dynamicBlock, 'pageSize', { fallback: 6, min: 1, max: 100 });
          break;
        case 'oeuvre':
          assignUrl(cloned as any, 'cardBackgroundImageUrl');
          if (Array.isArray(dynamicBlock.artworks)) {
            dynamicBlock.artworks = dynamicBlock.artworks.filter((id: unknown) => typeof id === 'string' && id.trim().length > 0);
          }
          setOptionalInt(dynamicBlock, 'columns', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columnsMobile', { fallback: 2, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'columnsDesktop', { fallback: 3, min: 1, max: 6 });
          setOptionalInt(dynamicBlock, 'gap', { fallback: 16, min: 0, max: 200 });
          setOptionalInt(dynamicBlock, 'limit', { fallback: 0, min: 0, max: 500 });
          setOptionalInt(dynamicBlock, 'borderThickness', { fallback: 1, min: 0, max: 20 });
          break;
        case 'eventList':
          if (Array.isArray(dynamicBlock.events)) {
            dynamicBlock.events = dynamicBlock.events.map((evt: any) => {
              if (!evt || typeof evt !== 'object') return evt;
              const next = { ...evt };
              assignUrl(next, 'linkUrl', { allowRelative: false });
              return next;
            });
          }
          break;
        case 'divider':
          setOptionalInt(dynamicBlock, 'thickness', { fallback: 1, min: 0, max: 20 });
          break;
        default:
          break;
      }
      return cloned;
    };
    return list.map((block: Block) => sanitizeBlock(block));
  }, [coerceNumber]);

  const sanitizeThemeForSave = React.useCallback((themeConfig: ThemeConfig) => {
    const next: ThemeConfig = { ...(themeConfig || {}) };
    const applyUrl = (key: keyof ThemeConfig, options?: NormalizeCmsUrlOptions) => {
      const raw = next[key];
      if (typeof raw !== 'string') return;
      const safe = normalizeCmsUrl(raw, { allowRelative: true, allowData: true, ...(options || {}) });
      if (safe) {
        next[key] = safe as any;
      } else {
        delete next[key];
      }
    };
    applyUrl('backgroundImageUrl');
    applyUrl('coverImageUrl');
    return next;
  }, []);

  const analyzeBlockContent = React.useCallback((list: Block[]) => {
    const missingAlt: string[] = [];
    const invalidUrls: string[] = [];
    const isAltMissingValue = (value: unknown, decorative?: boolean) => {
      if (decorative) return false;
      const normalized = typeof value === 'string' ? value.trim() : '';
      if (!normalized) return true;
      return /^image\d+$/i.test(normalized);
    };
    const checkUrl = (value: unknown, label: string, options?: NormalizeCmsUrlOptions) => {
      if (typeof value !== 'string' || value.trim().length === 0) return;
      const safe = normalizeCmsUrl(value, { allowRelative: true, allowData: true, ...(options || {}) });
      if (!safe) invalidUrls.push(label);
    };
    const walk = (block: Block, trail: string) => {
      switch (block.type) {
        case 'image': {
          const b = block as ImageBlock;
          if (isAltMissingValue(b.altText, b.decorative)) missingAlt.push(trail);
          checkUrl(b.src, `${trail} • image`, {});
          break;
        }
        case 'gallery': {
          const b = block as any; // GalleryBlock interface definition needed for strictness, falling back to any for deep props if not available
          if (Array.isArray(b.images)) {
            b.images.forEach((img: any, index: number) => {
              const label = `${trail} • image #${index + 1} `;
              if (isAltMissingValue(img?.altText, img?.decorative)) missingAlt.push(label);
              checkUrl(img?.src, label, {});
            });
          }
          break;
        }
        case 'button': {
          const b = block as ButtonBlock;
          checkUrl(b.url, `${trail} • lien`, { allowRelative: false });
          break;
        }
        case 'embed': {
          const b = block as EmbedBlock;
          checkUrl(b.url, `${trail} • intégration`, { allowRelative: false, allowMailto: false, allowData: false });
          break;
        }
        case 'video': {
          const b = block as any;
          checkUrl(b.src, `${trail} • vidéo`, { allowRelative: false, allowMailto: false, allowData: false });
          checkUrl(b.poster, `${trail} • poster`);
          break;
        }
        case 'artworkList':
        case 'oeuvre': {
          const b = block as any;
          checkUrl(b.cardBackgroundImageUrl, `${trail} • fond carte`);
          break;
        }
        case 'eventList': {
          const b = block as any;
          if (Array.isArray(b.events)) {
            b.events.forEach((evt: any, index: number) => {
              checkUrl(evt?.linkUrl, `${trail} • événement ${index + 1} `, { allowRelative: false });
            });
          }
          break;
        }
        case 'container': {
          const b = block as any;
          if (Array.isArray(b.children)) {
            b.children.forEach((child: Block, index: number) => walk(child, `${trail} > bloc ${index + 1} `));
          }
          break;
        }
        case 'columns': {
          const b = block as any;
          if (Array.isArray(b.columns)) {
            b.columns.forEach((col: Block[], colIndex: number) => {
              col?.forEach((child: Block, index: number) => walk(child, `${trail} > colonne ${colIndex + 1} / bloc ${index + 1}`));
            });
          }
          break;
        }
        default:
          break;
      }
      const bg = block.style?.backgroundImageUrl;
      if (bg) checkUrl(bg, `${trail} • image de fond`);
    };
    list.forEach((blk, idx) => walk(blk, `Bloc ${idx + 1}`));
    return { missingAlt, invalidUrls };
  }, []);
  const contentIssues = React.useMemo(() => analyzeBlockContent(blocks), [blocks, analyzeBlockContent]);

  const sanitizeMetaForSave = React.useCallback((currentMeta: typeof meta) => {
    const next = { ...(currentMeta || {}) };
    if (typeof next.canonicalUrl === 'string') {
      const sanitized = normalizeCmsUrl(next.canonicalUrl, { allowRelative: false, allowMailto: false, allowData: false });
      next.canonicalUrl = sanitized || '';
    }
    return next;
  }, []);



  const renderBlock = (
    block: Block,
    idx: number,
    suppressSelectionHandlers: boolean = false,
    mode: EditorMode = viewMode,
  ) => {
    const isEdit = mode === 'edit';
    const isPreview = mode === 'preview';
    if (block.type !== 'text') {
      const blockId = block.id;
      if (blockId) {
        delete textCommandHandlersRef.current[blockId];
      }
    }

    // Context for Universal Renderer
    const renderContext: RenderContext = {
      artist: {
        id: artistData.id,
        name: artistData.name || '',
        photoUrl: artistData.photoUrl,
        biography: artistData.biography,
        artworks: artistData.artworks || []
      } as any,
      sanitize: sanitizeRichText,
      searchString: '',
      isPreview: mode === 'edit',
      useNextLink: false,
      LinkComponent: 'div',
      pageKey: (pageKey || 'profile') as any,
      isMobile: device === 'mobile',
      disablePositioning: true
    };

    const renderUniversal = (b: Block, withOverlays: React.ReactNode = null) => {
      return (
        <div
          key={b.id}
          className={isEdit ? "relative cursor-pointer group" : undefined}
          onClick={(isEdit && !suppressSelectionHandlers) ? (e) => { e.stopPropagation(); setSelectedIndex(idx); } : undefined}
        >
          {/* Editor Overlays (Drag Handle for Absolute, Warnings) */}
          {isEdit && device !== 'mobile' && b.style?.position === 'absolute' && (
            <div className="absolute -top-3 -left-3 z-50 pointer-events-auto" title="Glisser pour déplacer">
              <div className="w-6 h-6 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center shadow cursor-move" onMouseDown={(e) => startAbsDrag(e, b)}>↕</div>
            </div>
          )}
          {withOverlays}
          <SingleBlockRenderer
            block={b}
            index={idx}
            context={renderContext}
          />
        </div>
      );
    };

    switch (block.type) {
      case 'text': {
        if (isPreview) {
          return renderUniversal(block);
        }
        const blockId = block.id;

        const textStyle: React.CSSProperties = {
          minHeight: '1.5rem',
          ...(block.alignment ? { textAlign: block.alignment } : {}),
          ...(block.fontSize ? { fontSize: block.fontSize } : {}),
          ...(block.color ? { color: block.color } : {}),
          ...(block.lineHeight ? { lineHeight: block.lineHeight } : {}),
          ...(block.letterSpacing ? { letterSpacing: block.letterSpacing } : {}),
          ...(block.fontWeight ? { fontWeight: block.fontWeight } : {}),
          ...(block.textTransform ? { textTransform: block.textTransform } : {}),
          ...(block.fontFamily ? { fontFamily: resolveFontFamily(block.fontFamily) } : {}),
        };

        return (
          <EditableTextBlock
            key={block.id}
            id={blockId}
            dataBlockId={blockId}
            initialContent={block.content || ''}
            className="cursor-text outline-none focus:ring-0"
            textStyle={textStyle}
            wrapperStyle={computeWrapperStyle(block)}
            isEdit={true}
            pageKey={pageKey}
            onUpdate={(val) => {
              if (blockId) {
                updateBlockById(blockId, current => ({ ...current, content: val } as any));
              }
            }}
            onRegister={(id, api) => {
              textCommandHandlersRef.current[id] = api;
            }}
            onAlign={(align) => {
              if (blockId) {
                updateBlockById(blockId, current => ({ ...current, alignment: align } as any));
              }
            }}
          >
            {(isEdit && block.style?.position === 'absolute') && (
              <div className="absolute -top-3 -left-3 z-10" title="Glisser pour déplacer (position absolue)">
                <div className="w-6 h-6 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center shadow cursor-move" onMouseDown={(e) => startAbsDrag(e, block)}>↕</div>
              </div>
            )}
            {(() => { const css = buildHoverCSS(block); return css ? <style dangerouslySetInnerHTML={{ __html: css }} /> : null })()}
          </EditableTextBlock>
        );
      }
      case 'image': {
        const needsAlt = !block.altText || /^image\d+$/i.test(String(block.altText).trim());
        const warningOverlay = (isEdit && needsAlt) ? (
          <>
            <button
              type="button"
              onClick={(e) => { e.stopPropagation(); setSelectedIndex(idx); setAltHelpOpenId(prev => prev === block.id ? null : block.id); setTimeout(() => inspectorContainerRef.current?.focus(), 0); }}
              title="Texte alternatif manquant/recomposé"
              className="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-red-600 text-white text-xs flex items-center justify-center shadow z-50"
            >?</button>
            {altHelpOpenId === block.id && (
              <div className="absolute left-2 top-4 z-50 w-72 bg-white border border-red-200 rounded shadow p-2 text-xs text-gray-700" onClick={(e) => e.stopPropagation()}>
                <div className="font-semibold text-red-600 mb-1">Texte alternatif recommandé</div>
                <p className="leading-relaxed">Le texte alternatif améliore l’accessibilité (lecteurs d’écran) et le SEO. Décrivez brièvement l’image (ex: “Portrait de l’artiste”).</p>
                <div className="mt-2 flex justify-end">
                  <button className="px-2 py-1 text-xs rounded bg-gray-100 hover:bg-gray-200" onClick={(e) => { e.stopPropagation(); setAltHelpOpenId(null); }}>OK</button>
                </div>
              </div>
            )}
          </>
        ) : null;
        return renderUniversal(block, warningOverlay);
      }
      case 'gallery': {
        const missingCount = (block.images || []).filter((img: GalleryImage) => !img.altText || /^image\d+$/i.test(String(img.altText).trim())).length;
        const warningOverlay = (isEdit && missingCount > 0) ? (
          <>
            <button
              type="button"
              onClick={(e) => { e.stopPropagation(); setSelectedIndex(idx); setAltHelpOpenId(prev => prev === block.id ? null : block.id); setTimeout(() => inspectorContainerRef.current?.focus(), 0); }}
              title="Texte alternatif manquant/recomposé"
              className="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-red-600 text-white text-xs flex items-center justify-center shadow z-50"
            >?</button>
            {altHelpOpenId === block.id && (
              <div className="absolute left-2 top-4 z-50 w-80 bg-white border border-red-200 rounded shadow p-2 text-xs text-gray-700" onClick={(e) => e.stopPropagation()}>
                <div className="font-semibold text-red-600 mb-1">Texte alternatif recommandé</div>
                <p className="leading-relaxed">{`Certaines images de cette galerie n'ont pas de texte alternatif personnalisé (${missingCount}). Le texte alternatif améliore l’accessibilité et le SEO. Décrivez brièvement chaque image.`}</p>
                <div className="mt-2 flex justify-end">
                  <button className="px-2 py-1 text-xs rounded bg-gray-100 hover:bg-gray-200" onClick={(e) => { e.stopPropagation(); setAltHelpOpenId(null); }}>OK</button>
                </div>
              </div>
            )}
          </>
        ) : null;
        return renderUniversal(block, warningOverlay);
      }
      case 'video': return renderUniversal(block);
      case 'embed': return renderUniversal(block);
      case 'divider': return renderUniversal(block);
      case 'quote': return renderUniversal(block);
      case 'oeuvre': return renderUniversal(block);
      case 'artworkList': return renderUniversal(block);
      case 'spacer': return renderUniversal(block);
      case 'columns': {
        const colBlock = block;
        const wrapperStyle: React.CSSProperties = computeWrapperStyle(colBlock);
        // helper to handle drop at an index inside a column
        const handleDropAt = (e: React.DragEvent, colIdx: number, insertAt: number) => {
          e.preventDefault(); e.stopPropagation();
          const type = e.dataTransfer.getData('block-type') as BlockType;
          const movingBlockId = e.dataTransfer.getData('move-block-id');
          const movingChildRaw = e.dataTransfer.getData('move-container-child');
          const wrapper = (e.currentTarget as HTMLElement).closest('[data-container-index]') as HTMLElement | null;
          if (wrapper) {
            const containerIndex = parseInt(String(wrapper.getAttribute('data-container-index')), 10);
            const columnsChildId = String(wrapper.getAttribute('data-child-id'));
            if (movingBlockId) {
              setBlocks(prev => {
                const arr = [...prev];
                const fromIdx = arr.findIndex(b => b.id === movingBlockId);
                if (fromIdx >= 0) {
                  const [moved] = arr.splice(fromIdx, 1);
                  const cont = arr[containerIndex] as any;
                  const childIdx2 = (cont.children || []).findIndex((c: any) => c.id === columnsChildId);
                  if (childIdx2 >= 0) {
                    const columnsBlk = cont.children[childIdx2] as any;
                    const target = columnsBlk.columns[colIdx] || [];
                    const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, moved);
                    const newCols = columnsBlk.columns.map((c: Block[], i: number) => (i === colIdx ? newCol : c));
                    cont.children = cont.children.slice();
                    cont.children[childIdx2] = { ...columnsBlk, columns: newCols };
                  }
                }
                return arr;
              });
            } else if (movingChildRaw) {
              try {
                const payload = JSON.parse(movingChildRaw);
                const { parentIndex: fromParentIdx, childId } = payload as { parentIndex: number; childId: string };
                setBlocks(prev => {
                  const arr = [...prev];
                  const fromCont = arr[fromParentIdx] as any;
                  const child = (fromCont.children || []).find((c: any) => c.id === childId);
                  if (!child) return arr;
                  fromCont.children = (fromCont.children || []).filter((c: any) => c.id !== childId);
                  const toCont = arr[containerIndex] as any;
                  const childIdx2 = (toCont.children || []).findIndex((c: any) => c.id === columnsChildId);
                  if (childIdx2 >= 0) {
                    const columnsBlk = toCont.children[childIdx2] as any;
                    const target = columnsBlk.columns[colIdx] || [];
                    const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, child);
                    const newCols = columnsBlk.columns.map((c: Block[], i: number) => (i === colIdx ? newCol : c));
                    toCont.children = toCont.children.slice();
                    toCont.children[childIdx2] = { ...columnsBlk, columns: newCols };
                  }
                  return arr;
                });
              } catch { }
            } else if (type) {
              const child = createBlockInstance(type);
              setBlocks(prev => prev.map((b, i) => {
                if (i !== containerIndex || b.type !== 'container') return b;
                const cont = b as any;
                const childIdx2 = (cont.children || []).findIndex((c: any) => c.id === columnsChildId);
                if (childIdx2 < 0) return b;
                const columnsBlk = cont.children[childIdx2] as any;
                const target = columnsBlk.columns[colIdx] || [];
                const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, child);
                const newCols = columnsBlk.columns.map((c: Block[], i2: number) => (i2 === colIdx ? newCol : c));
                const newChildren = cont.children.slice();
                newChildren[childIdx2] = { ...columnsBlk, columns: newCols };
                return { ...cont, children: newChildren };
              }));
            }
            return;
          }
          // root columns on canvas
          if (movingBlockId) {
            setBlocks(prev => {
              const arr = [...prev];
              const fromIdx = arr.findIndex(b => b.id === movingBlockId);
              if (fromIdx >= 0) {
                const [moved] = arr.splice(fromIdx, 1);
                const parent = arr[idx] as any;
                const target = parent.columns[colIdx] || [];
                const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, moved);
                const newCols = parent.columns.map((c: Block[], i: number) => (i === colIdx ? newCol : c));
                arr[idx] = { ...parent, columns: newCols };
              }
              return arr;
            });
          } else if (movingChildRaw) {
            try {
              const payload = JSON.parse(movingChildRaw);
              const { parentIndex: fromParentIdx, childId } = payload as { parentIndex: number; childId: string };
              setBlocks(prev => {
                const arr = [...prev];
                const fromCont = arr[fromParentIdx] as any;
                const child = (fromCont.children || []).find((c: any) => c.id === childId);
                if (!child) return arr;
                fromCont.children = (fromCont.children || []).filter((c: any) => c.id !== childId);
                const parent = arr[idx] as any;
                const target = parent.columns[colIdx] || [];
                const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, child);
                const newCols = parent.columns.map((c: Block[], i: number) => (i === colIdx ? newCol : c));
                arr[idx] = { ...parent, columns: newCols };
                return arr;
              });
            } catch { }
          } else if (type) {
            const child = createBlockInstance(type);
            setBlocks(prev => prev.map((b, i) => {
              if (i !== idx || b.type !== 'columns') return b;
              const parent = b as any;
              const target = parent.columns[colIdx] || [];
              const newCol = [...target]; newCol.splice(Math.max(0, Math.min(insertAt, newCol.length)), 0, child);
              const newCols = parent.columns.map((c: Block[], i2: number) => (i2 === colIdx ? newCol : c));
              return { ...parent, columns: newCols };
            }));
          }
        };
        const DropZone = ({ colIdx, insertAt }: { colIdx: number; insertAt: number }) => {
          const isDragging = !!activeDragType; // Uses variable from parent scope
          if (!isDragging) return <div className="h-2 w-full -my-1 bg-transparent z-10" />; // Invisible spacer for stability? Or just null? Null causes shifts. Let's return null for now to see preference. Or keep a tiny hot zone?
          // User said "invisible".
          // If I return slightly visible on Drag?
          return (
            <div
              className={`h-4 my-1 border border-dashed border-blue-300 bg-blue-50/30 rounded transition-all duration-200 ${isDragging ? 'opacity-100 translate-y-0' : 'opacity-0 h-0 my-0 overflow-hidden'}`}
              onDragOver={e => e.preventDefault()}
              onDrop={e => handleDropAt(e, colIdx, insertAt)}
            />
          );
        };
        const insideContainer = suppressSelectionHandlers;
        const renderColumn = (col: Block[], colIdx: number) => {
          const content = (
            <>
              <DropZone colIdx={colIdx} insertAt={0} />
              {col.length === 0 && (
                <div className="h-full min-h-[60px] flex items-center justify-center border border-dashed border-slate-200 rounded text-xs text-slate-400 font-medium select-none pointer-events-none">
                  Colonne vide
                </div>
              )}
              {col.map((child: Block, childIdx: number) => {
                const columnBlockId = colBlock.id;
                const cs: any = (child as any).style || {};
                const js = (cs.canvasAlign === 'center') ? 'center' : (cs.canvasAlign === 'right') ? 'end' : 'start';
                const itemWrapper: React.CSSProperties = { justifySelf: js, zIndex: cs.zIndex } as any;
                if (cs.width) itemWrapper.width = cs.width;
                const handleRemoveChild = () => {
                  if (!columnBlockId) return;
                  updateBlockById(columnBlockId, (currentParent: any) => {
                    if (!currentParent || currentParent.type !== 'columns' || !Array.isArray(currentParent.columns)) {
                      return currentParent;
                    }
                    const newCols = currentParent.columns.map((colArr: Block[], cIdx: number) =>
                      cIdx === colIdx ? colArr.filter((_, i) => i !== childIdx) : colArr
                    );
                    return { ...currentParent, columns: newCols };
                  });

                };
                return (
                  <div
                    key={child.id}
                    className={`relative mb-2 ${isEdit ? 'cursor-pointer hover:ring-1 hover:ring-blue-300 rounded' : ''}`}
                    style={itemWrapper}
                    onClick={isEdit ? (e) => {
                      e.stopPropagation();
                      e.nativeEvent.stopImmediatePropagation();
                      setSelectedIndex(idx); // Ensure parent is active context
                      setSelectedChild({ parentId: colBlock.id, childId: child.id });
                    } : undefined}
                  >
                    {isEdit && (
                      <div
                        className="absolute top-6 right-1 z-10 flex space-x-1"
                        onPointerDown={e => { e.stopPropagation(); e.nativeEvent.stopImmediatePropagation(); }}
                      >
                        <button
                          type="button"
                          onClick={e => { e.stopPropagation(); handleRemoveChild(); }}
                          title="Supprimer"
                          className="w-6 h-6 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full shadow text-red-600 hover:text-red-800 transition"
                        >
                          ×
                        </button>
                        <button
                          type="button"
                          onClick={e => { e.stopPropagation(); setSelectedChild({ parentId: colBlock.id, childId: child.id }); }}
                          title="Éditer"
                          className="w-6 h-6 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full shadow text-blue-600 hover:text-blue-800 transition"
                        >
                          ✎
                        </button>
                      </div>
                    )}
                    {renderBlock(child, idx, true, mode)}
                    <DropZone colIdx={colIdx} insertAt={childIdx + 1} />
                  </div>
                );
              })}
            </>
          );
          if (insideContainer) {
            const droppableId = `${CONTAINER_COLUMN_DROPPABLE_PREFIX}${colBlock.id}:${colIdx}`;
            // Clean editor style: transparent by default, ring on hover
            const columnClasses = "relative flex-1 p-3 min-h-[80px] rounded-lg transition-all duration-200 hover:ring-1 hover:ring-slate-300";

            return (
              <ColumnDroppable
                key={`${colBlock.id}-${colIdx}`}
                droppableId={droppableId}
                data-col-index={colIdx}
                className={columnClasses}
              >
                {content}
              </ColumnDroppable>
            );
          }
          // Fallback static div
          return (
            <div key={colIdx} data-col-index={colIdx} className="flex-1 p-3 min-h-[80px] rounded-lg transition-all duration-200 hover:ring-1 hover:ring-slate-300">
              {content}
            </div>
          );
        };
        return (
          <div
            key={block.id}
            className={isEdit ? 'border p-2 cursor-pointer' : undefined}
            onClick={isEdit && !suppressSelectionHandlers ? (() => setSelectedIndex(idx)) : undefined}
            style={wrapperStyle}
          >
            <div className="flex gap-4">
              {colBlock.columns.map((col: Block[], colIdx: number) => renderColumn(col, colIdx))}
            </div>
          </div>
        );
      }
      // Section conteneur pour regrouper plusieurs blocs
      case 'container': {
        const cb = block;
        const wrapperStyle: React.CSSProperties = computeWrapperStyle(cb);
        const hasAbsoluteChild = Array.isArray(cb.children) && cb.children.some((ch: Block) => (ch.style?.position === 'absolute'));
        if (hasAbsoluteChild) {
          if (!wrapperStyle.position) wrapperStyle.position = 'relative';
          const clampAny = (cb.children || []).some((ch: any) => ch?.style?.absoluteClamp);
          if (clampAny && !wrapperStyle.overflow) wrapperStyle.overflow = 'hidden';
        }
        if (isEdit && cb?.style?.gridOverlay8) {
          const grid = 'repeating-linear-gradient(0deg, rgba(0,0,0,0.05) 0, rgba(0,0,0,0.05) 1px, transparent 1px, transparent 8px), repeating-linear-gradient(90deg, rgba(0,0,0,0.05) 0, rgba(0,0,0,0.05) 1px, transparent 1px, transparent 8px)';
          if (wrapperStyle.backgroundImage) {
            wrapperStyle.backgroundImage = grid + ', ' + String(wrapperStyle.backgroundImage);
          } else {
            wrapperStyle.backgroundImage = grid;
          }
          wrapperStyle.backgroundSize = '8px 8px, 8px 8px';
        }
        const clampCols = (value: unknown, fallback: number): 1 | 2 | 3 | 4 => {
          const numeric = Number(value);
          if (!Number.isFinite(numeric)) return fallback as 1 | 2 | 3 | 4;
          const clamped = Math.max(1, Math.min(4, Math.round(numeric)));
          return (clamped || fallback) as 1 | 2 | 3 | 4;
        };
        const baseColsMap: Record<1 | 2 | 3 | 4, string> = {
          1: 'grid-cols-1',
          2: 'grid-cols-2',
          3: 'grid-cols-3',
          4: 'grid-cols-4',
        };
        const mdColsMap: Record<1 | 2 | 3 | 4, string> = {
          1: 'md:grid-cols-1',
          2: 'md:grid-cols-2',
          3: 'md:grid-cols-3',
          4: 'md:grid-cols-4',
        };
        const lgColsMap: Record<1 | 2 | 3 | 4, string> = {
          1: 'lg:grid-cols-1',
          2: 'lg:grid-cols-2',
          3: 'lg:grid-cols-3',
          4: 'lg:grid-cols-4',
        };
        const cols = clampCols(cb.columns ?? 1, 1);
        const gridColsClass = [
          baseColsMap[1], // Mobile always 1
          mdColsMap[cols > 1 ? 2 : 1], // Tablet auto?
          lgColsMap[cols], // Desktop = configured columns
        ].filter(Boolean).join(' ');
        const containerClassName = isEdit
          ? `w-full cursor-pointer border-2 border-dashed border-blue-400 ${isBanner ? 'bg-blue-50/70' : 'bg-blue-50 p-4'
          }`
          : undefined;
        return (
          <div
            key={block.id}
            className={containerClassName}
            onClick={isEdit ? (() => { setSelectedChild(null); setSelectedIndex(idx); }) : undefined}
            onDragOver={e => e.preventDefault()}
            style={wrapperStyle}
            onDrop={e => {
              e.preventDefault();
              e.stopPropagation();
              const type = e.dataTransfer.getData('block-type') as BlockType;
              const movingBlockId = e.dataTransfer.getData('move-block-id');
              const movingChildRaw = e.dataTransfer.getData('move-container-child');
              // Drop inside nested column?
              const colElem = (e.target as HTMLElement).closest('[data-col-index]');
              if (colElem) {
                const colIndex = parseInt(colElem.getAttribute('data-col-index') || '-1', 10);
                if (colIndex >= 0) {
                  // Identifier le bloc Columns enfant ciblé
                  const wrapper = (e.target as HTMLElement).closest('[data-container-index]') as HTMLElement | null;
                  const columnsChildId = wrapper ? wrapper.getAttribute('data-child-id') : null;
                  if (movingBlockId) {
                    // Déplacer un bloc existant du canvas vers une colonne d'un bloc colonnes contenu dans la section
                    setBlocks(prev => {
                      const arr = [...prev];
                      const fromIdx = arr.findIndex(b => b.id === movingBlockId);
                      if (fromIdx >= 0) {
                        const [moved] = arr.splice(fromIdx, 1);
                        const cont = arr[idx] as any;
                        if (columnsChildId) {
                          const childIdx2 = (cont.children || []).findIndex((c: any) => c.id === columnsChildId);
                          if (childIdx2 >= 0) {
                            const columnsBlk = cont.children[childIdx2] as any;
                            const target = columnsBlk.columns[colIndex] || [];
                            const newCol = [...target, moved];
                            const newCols = columnsBlk.columns.map((c: any[], i: number) => (i === colIndex ? newCol : c));
                            cont.children = cont.children.slice();
                            cont.children[childIdx2] = { ...columnsBlk, columns: newCols };
                          } else {
                            cont.children = [...(cont.children || []), moved];
                          }
                        } else {
                          cont.children = [...(cont.children || []), moved];
                        }
                      }
                      return arr;
                    });
                  } else if (movingChildRaw) {
                    // Déplacer un enfant d'une autre section directement dans une colonne ciblée
                    try {
                      const payload = JSON.parse(movingChildRaw);
                      const { parentIndex: fromParentIdx, childId } = payload as { parentIndex: number; childId: string };
                      setBlocks(prev => {
                        const arr = [...prev];
                        const fromCont = arr[fromParentIdx] as any;
                        const child = (fromCont.children || []).find((c: any) => c.id === childId);
                        if (!child) return arr;
                        fromCont.children = (fromCont.children || []).filter((c: any) => c.id !== childId);
                        const toCont = arr[idx] as any;
                        if (columnsChildId) {
                          const childIdx2 = (toCont.children || []).findIndex((c: any) => c.id === columnsChildId);
                          if (childIdx2 >= 0) {
                            const columnsBlk = toCont.children[childIdx2] as any;
                            const target = columnsBlk.columns[colIndex] || [];
                            const newCol = [...target, child];
                            const newCols = columnsBlk.columns.map((c: any[], i: number) => (i === colIndex ? newCol : c));
                            toCont.children = toCont.children.slice();
                            toCont.children[childIdx2] = { ...columnsBlk, columns: newCols };
                          } else {
                            toCont.children = [...(toCont.children || []), child];
                          }
                        } else {
                          toCont.children = [...(toCont.children || []), child];
                        }
                        return arr;
                      });
                    } catch { }
                  } else if (type) {
                    addBlockToColumn(idx, colIndex, type);
                  }
                  return;
                }
              }
              // Otherwise, add to this container
              if (movingBlockId) {
                // Déplacer un bloc existant du canvas vers cette section
                setBlocks(prev => {
                  const arr = [...prev];
                  const fromIdx = arr.findIndex(b => b.id === movingBlockId);
                  if (fromIdx >= 0) {
                    const [moved] = arr.splice(fromIdx, 1);
                    const cont = arr[idx] as any;
                    cont.children = [...(cont.children || []), moved];
                  }
                  return arr;
                });
              } else if (movingChildRaw) {
                // Déplacer un enfant d'une autre section vers celle-ci
                try {
                  const payload = JSON.parse(movingChildRaw);
                  const { parentIndex: fromParentIdx, childId } = payload as { parentIndex: number; childId: string };
                  if (fromParentIdx === idx) return; // même section
                  setBlocks(prev => {
                    const arr = [...prev];
                    const fromCont = arr[fromParentIdx] as any;
                    const child = (fromCont.children || []).find((c: any) => c.id === childId);
                    if (!child) return arr;
                    fromCont.children = (fromCont.children || []).filter((c: any) => c.id !== childId);
                    const toCont = arr[idx] as any;
                    toCont.children = [...(toCont.children || []), child];
                    return arr;
                  });

                } catch { }
              } else if (type) {
                addBlockToContainer(idx, type);
              }
            }}
          >
            {isEdit && (
              <div className="flex items-center mb-2 space-x-1">
                <LayoutGridIcon className="text-gray-600" size={16} />
                <strong className="text-gray-600">Section</strong>
              </div>
            )}
            {/* Zone d’édition en glisser-déposer - affichage en grille */}
            {isEdit && (
              <SortableContext
                items={cb.children.map((c: Block) => c.id)}
                strategy={(cb.columns || 1) > 1 ? rectSortingStrategy : verticalListSortingStrategy}
              >
                <div className={`grid ${gridColsClass}`} style={{ gap: normPx(cb.style?.gap, 16) }}>  {/* Grille de colonnes */}
                  {cb.children.map((child: Block, ci: number) => (
                    <ContainerSortableItem
                      key={child.id}
                      parentIndex={idx}
                      parentId={(cb as any).id}
                      child={child}
                      childIndex={ci}
                    />
                  ))}
                </div>
              </SortableContext>
            )}
            {/* Aperçu statique en grille */}
            {!isEdit && (
              <div className={`grid ${gridColsClass}`} style={{ gap: normPx(cb.style?.gap, 16) }}>  {/* Grille de colonnes */}
                {
                  cb.children.map((child: Block, ci: number) => (
                    <React.Fragment key={(child as any).id || ci}>{renderBlock(child, idx, false, mode)}</React.Fragment>
                  ))
                }
              </div>
            )}
          </div>
        );
      }
      case 'button': return renderUniversal(block);

      case 'artistName': return renderUniversal(block);
      case 'artistPhoto': return renderUniversal(block);
      case 'artistBio': return renderUniversal(block);
      case 'contactForm': return renderUniversal(block);
      case 'eventList': {
        const eb = block as any;
        const wrapperStyle: React.CSSProperties = computeWrapperStyle(eb);
        const accent = eb.accentColor || theme.primaryColor || '#1e3a8a';
        const layout: 'timeline' | 'cards' | 'list' = eb.layout || 'timeline';
        const showPastEvents = eb.showPastEvents !== false;
        const sortMode: 'manual' | 'startDateAsc' | 'startDateDesc' = eb.sortMode || 'startDateAsc';
        const showDates = eb.showDates !== false;
        const showLocation = eb.showLocation !== false;
        const showDescription = eb.showDescription !== false;
        const showLink = eb.showLink !== false;
        const condensed = !!eb.condensed;
        const heading = eb.heading as string | undefined;
        const badgeLabel = (eb.upcomingBadgeLabel && eb.upcomingBadgeLabel.trim().length > 0 ? eb.upcomingBadgeLabel.trim() : 'À venir');
        const emptyState = (eb.emptyStateMessage && eb.emptyStateMessage.trim().length > 0)
          ? eb.emptyStateMessage
          : (showPastEvents
            ? 'Ajoutez vos expositions, résidences ou performances via l’inspecteur.'
            : 'Aucun événement à venir pour le moment. Ajoutez vos prochaines dates via l’inspecteur.');
        const events = Array.isArray(eb.events) ? eb.events : [];
        const isEdit = viewMode === 'edit';
        const today = new Date(); today.setHours(0, 0, 0, 0);
        const todayTs = today.getTime();
        const formatDate = (iso?: string) => {
          if (!iso) return '';
          try {
            const d = new Date(iso);
            if (Number.isNaN(d.getTime())) return iso;
            return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
          } catch {
            return iso;
          }
        };
        const formatRange = (start?: string, end?: string) => {
          const startLabel = formatDate(start);
          const endLabel = end && end !== start ? formatDate(end) : '';
          if (startLabel && endLabel) return `${startLabel} – ${endLabel}`;
          return startLabel || endLabel;
        };
        const baseClass = isEdit ? 'border p-4 cursor-pointer relative' : undefined;
        const parseTimestamp = (value?: string) => {
          if (!value) return undefined;
          const d = new Date(value);
          if (Number.isNaN(d.getTime())) return undefined;
          return d.getTime();
        };
        const normalizedEvents = events.map((ev: any, index: number) => {
          const startTs = parseTimestamp(ev.startDate);
          const endTs = parseTimestamp(ev.endDate);
          const timestamps = [startTs, endTs].filter((ts): ts is number => typeof ts === 'number');
          const latestTs = timestamps.length > 0 ? Math.max(...timestamps) : undefined;
          const isUpcoming = latestTs !== undefined ? latestTs >= todayTs : true;
          const baseTs = startTs ?? endTs;
          return { ...ev, isUpcoming, startTs, endTs, baseTs, latestTs, originalIndex: index };
        });
        const orderedEvents = sortMode === 'manual'
          ? normalizedEvents
          : [...normalizedEvents].sort((a: any, b: any) => {
            const fallback = sortMode === 'startDateAsc' ? Number.MAX_SAFE_INTEGER : Number.MIN_SAFE_INTEGER;
            const aTs = typeof a.baseTs === 'number' ? a.baseTs : fallback;
            const bTs = typeof b.baseTs === 'number' ? b.baseTs : fallback;
            if (aTs === bTs) return (a.originalIndex ?? 0) - (b.originalIndex ?? 0);
            return sortMode === 'startDateAsc' ? aTs - bTs : bTs - aTs;
          });
        const visibleEvents = showPastEvents ? orderedEvents : orderedEvents.filter((ev: any) => ev.isUpcoming || ev.highlight);
        const renderTimeline = () => (
          <div className="relative" style={{ paddingLeft: '1.5rem' }}>
            <div style={{ position: 'absolute', left: '10px', top: 0, bottom: 0, width: '2px', background: `${accent}22` }} aria-hidden />
            <div className={`flex flex-col ${condensed ? 'gap-4' : 'gap-8'}`}>
              {visibleEvents.map((ev: any, index: number) => {
                const range = showDates ? formatRange(ev.startDate, ev.endDate) : '';
                const location = showLocation && ev.location ? ev.location : '';
                const highlight = ev.highlight || ev.isUpcoming;
                return (
                  <div key={ev.id || index} className="relative bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60 rounded-lg border border-gray-200 shadow-sm p-4">
                    <div
                      style={{
                        position: 'absolute',
                        left: '-15px',
                        top: '18px',
                        width: '12px',
                        height: '12px',
                        borderRadius: '9999px',
                        border: `2px solid ${accent}`,
                        background: highlight ? accent : '#ffffff',
                      }}
                      aria-hidden
                    />
                    <div className="flex flex-col gap-2">
                      <div className="flex flex-wrap items-center gap-2">
                        <span className="text-base font-semibold" style={{ fontFamily: resolveFontFamily(theme.headingFont) }}>{ev.title || 'Événement sans titre'}</span>
                        {highlight && (
                          <span className="text-xs uppercase tracking-wide px-2 py-0.5 rounded-full" style={{ background: `${accent}15`, color: accent }}>
                            {badgeLabel}
                          </span>
                        )}
                      </div>
                      {(range || location) && (
                        <div className="flex flex-wrap gap-3 text-sm text-gray-600">
                          {range && <span className="inline-flex items-center gap-1 font-medium" style={{ color: accent }}>
                            <CalendarIcon size={14} />
                            {range}
                          </span>}
                          {location && (<span className="inline-flex items-center gap-1">
                            <span role="img" aria-hidden>📍</span>
                            {location}
                          </span>)}
                        </div>
                      )}
                      {showDescription && ev.description && (
                        <p className="text-sm leading-relaxed text-gray-700">{ev.description}</p>
                      )}
                      {showLink && ev.linkUrl && (
                        <a
                          href={ev.linkUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          className="inline-flex items-center gap-2 text-sm font-medium"
                          style={{ color: accent }}
                        >
                          {ev.linkLabel || 'En savoir plus'}
                          <span aria-hidden>↗</span>
                        </a>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
        const renderCards = () => (
          <div className={`grid ${condensed ? 'md:grid-cols-2 gap-4' : 'md:grid-cols-3 gap-6'} grid-cols-1`}>
            {visibleEvents.map((ev: any, index: number) => {
              const range = showDates ? formatRange(ev.startDate, ev.endDate) : '';
              const location = showLocation && ev.location ? ev.location : '';
              const highlight = ev.highlight || ev.isUpcoming;
              return (
                <div
                  key={ev.id || index}
                  className="rounded-xl border shadow-sm bg-white/80 backdrop-blur supports-[backdrop-filter]:bg-white/60 p-5 flex flex-col gap-3"
                  style={{ borderColor: highlight ? accent : 'rgba(209,213,219,1)' }}
                >
                  <div className="flex flex-wrap items-start justify-between gap-2">
                    <div>
                      <div className="text-sm uppercase tracking-wide text-gray-500" style={{ color: `${accent}AA` }}>{range || 'Dates à venir'}</div>
                      <div className="text-lg font-semibold" style={{ fontFamily: resolveFontFamily(theme.headingFont) }}>{ev.title || 'Événement sans titre'}</div>
                    </div>
                    {highlight && (
                      <span className="text-[11px] px-2 py-0.5 rounded-full border" style={{ borderColor: accent, color: accent }}>{badgeLabel}</span>
                    )}
                  </div>
                  {location && <div className="text-sm text-gray-600">{location}</div>}
                  {showDescription && ev.description && <p className="text-sm leading-relaxed text-gray-700">{ev.description}</p>}
                  {showLink && ev.linkUrl && (
                    <a href={ev.linkUrl} target="_blank" rel="noopener noreferrer" className="text-sm font-medium" style={{ color: accent }}>
                      {ev.linkLabel || 'Découvrir'} ↗
                    </a>
                  )}
                </div>
              );
            })}
          </div>
        );
        const renderList = () => (
          <div className="space-y-4">
            {visibleEvents.map((ev: any, index: number) => {
              const range = showDates ? formatRange(ev.startDate, ev.endDate) : '';
              const location = showLocation && ev.location ? ev.location : '';
              const highlight = ev.highlight || ev.isUpcoming;
              return (
                <div key={ev.id || index} className="flex flex-col md:flex-row md:items-center md:gap-6 gap-2 border-b pb-4 last:border-0 last:pb-0 border-gray-200">
                  <div className="min-w-[180px]">
                    {range && <div className="text-sm font-medium" style={{ color: accent }}>{range}</div>}
                    {location && <div className="text-sm text-gray-600">{location}</div>}
                  </div>
                  <div className="flex-1">
                    <div className="flex flex-wrap items-center gap-2">
                      <span className="text-base font-semibold" style={{ fontFamily: resolveFontFamily(theme.headingFont) }}>{ev.title || 'Événement sans titre'}</span>
                      {highlight && (<span className="text-xs uppercase tracking-wide px-2 py-0.5 rounded-full" style={{ background: `${accent}15`, color: accent }}>{badgeLabel}</span>)}
                    </div>
                    {showDescription && ev.description && <p className="text-sm leading-relaxed text-gray-700 mt-1">{ev.description}</p>}
                    {showLink && ev.linkUrl && (
                      <a href={ev.linkUrl} target="_blank" rel="noopener noreferrer" className="text-sm font-medium inline-flex items-center gap-1 mt-2" style={{ color: accent }}>
                        {ev.linkLabel || 'En savoir plus'}
                        <span aria-hidden>↗</span>
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        );
        return (
          <div
            id={`blk-${(block as any).id}`}
            key={block.id}
            className={baseClass}
            data-block-id={(block as any).id}
            style={wrapperStyle}
            onClick={undefined}
          >
            {(isEdit && (block as any)?.style?.position === 'absolute') && (
              <div className="absolute -top-3 -left-3 z-10" title="Glisser pour déplacer (position absolue)">
                <div className="w-6 h-6 rounded-full bg-blue-600 text-white text-xs flex items-center justify-center shadow cursor-move" onMouseDown={(e) => startAbsDrag(e, block)}>↕</div>
              </div>
            )}
            {heading && <div className="text-lg font-semibold mb-3" style={{ fontFamily: resolveFontFamily(theme.headingFont), color: accent }}>{heading}</div>}
            {visibleEvents.length === 0 ? (
              <div className="text-sm text-gray-600 italic">
                {emptyState}
              </div>
            ) : (
              <div className="space-y-4">
                {layout === 'timeline' && renderTimeline()}
                {layout === 'cards' && renderCards()}
                {layout === 'list' && renderList()}
              </div>
            )}
          </div>
        );
      }
      default:
        return null;
    }
  };
  /**
   * Rendu simplifié pour l'aperçu final (WYSIWYG)
   */
  const renderPreviewBlock = (block: Block, idx: number): React.ReactNode => {
    return renderBlock(block, idx, false, 'preview') as any;
  };


  // Préférences d'auto-save (activé/désactivé + délai)
  const [autoSaveEnabled] = useState<boolean>(initialSettings.autoSaveEnabled ?? true);
  const [autoSaveDelayMs] = useState<number>(initialSettings.autoSaveDelayMs ?? 8000);
  const bannerSettings = React.useMemo(() => ({ applyThemeToHome }), [applyThemeToHome]);
  const localKey = React.useMemo(() => `cmsLocalDraft:${(pageKey || 'profile')}`, [pageKey]);
  const saveLocalBackup = useCallback((overrideBlocks?: Block[], overrideMeta?: typeof meta) => {
    try {
      const data = {
        blocks: overrideBlocks || blocks,
        theme: sanitizeThemeForSave(theme),
        meta: overrideMeta || meta,
        settings: { autoSaveEnabled, autoSaveDelayMs, applyThemeToHome },
      };
      window.localStorage.setItem(localKey, JSON.stringify(data));
    } catch { }
  }, [blocks, theme, meta, autoSaveEnabled, autoSaveDelayMs, applyThemeToHome, localKey, sanitizeThemeForSave]);
  const extractResponseError = useCallback(async (res: Response): Promise<string> => {
    const clone = res.clone();
    try {
      const data = await res.json();
      const pieces: string[] = [];
      if (typeof data?.error === 'string' && data.error.trim().length > 0) {
        pieces.push(data.error.trim());
      }
      const details = data?.details;
      if (details) {
        if (Array.isArray(details.formErrors)) {
          pieces.push(...details.formErrors.filter((msg: unknown): msg is string => typeof msg === 'string' && msg.trim().length > 0));
        }
        if (details.fieldErrors && typeof details.fieldErrors === 'object') {
          Object.entries(details.fieldErrors).forEach(([field, messages]) => {
            if (Array.isArray(messages)) {
              const clean = messages.filter((msg: unknown): msg is string => typeof msg === 'string' && msg.trim().length > 0);
              if (clean.length > 0) {
                pieces.push(`${field}: ${clean.join(', ')}`);
              }
            }
          });
        }
      }
      if (pieces.length > 0) return pieces.join(' — ');
    } catch { }
    try {
      const text = await clone.text();
      if (text.trim().length > 0) return text;
    } catch { }
    return res.statusText || `Erreur ${res.status}`;
  }, []);
  const handleSave = useCallback(async () => {

    setSaving(true);
    // Auto-fill alt text for images/galleries when missing and inform the user.
    let autoFilled = false; let counter = 1;
    const isEmpty = (s: unknown) => !s || String(s).trim().length === 0;
    const fill = (arr: Block[]): Block[] => arr.map((b: Block) => {
      if (b.type === 'image') {
        const imageBlock = b as ImageBlock;
        if (isEmpty(imageBlock.altText)) { return { ...imageBlock, altText: `image${counter++}` }; autoFilled = true; }
        return b;
      }
      if (b.type === 'gallery') {
        // GalleryBlock logic
        const galleryBlock = b as any; // Allow lazy access for now if GalleryBlock not fully strict
        if (Array.isArray(galleryBlock.images)) {
          const images = galleryBlock.images.map((img: any) => {
            if (isEmpty(img.altText)) { autoFilled = true; return { ...img, altText: `image${counter++}` }; }
            return img;
          });
          return { ...b, images } as Block;
        }
        return b;
      }
      if (b.type === 'container') {
        const containerBlock = b as ContainerBlock;
        if (Array.isArray(containerBlock.children)) {
          const children = containerBlock.children.map((ch: Block) => (fill([ch])[0]));
          return { ...b, children } as Block;
        }
        return b;
      }
      if (b.type === 'columns') {
        const columnsBlock = b as ColumnBlock;
        if (Array.isArray(columnsBlock.columns)) {
          const columns = columnsBlock.columns.map((col: Block[]) => fill(col));
          return { ...b, columns } as Block;
        }
        return b;
      }
      return b;
    });
    const updatedBlocks = fill(blocks);
    if (autoFilled) {
      setBlocks(updatedBlocks);
      addToast('Des textes alternatifs ont été ajoutés automatiquement (ex: "image1"). Pensez à les personnaliser.', 'info');
    }
    const blocksCandidate = autoFilled ? updatedBlocks : blocks;
    // Sanitize blocks as before
    const blocksForSave = sanitizeBlocksForSave(blocksCandidate);

    // NEW: Build structured content from sanitized blocks
    const blocksDataForSave = Object.fromEntries(
      Object.entries(blocksData).map(([id, block]) => {
        // Find sanitized version if exists in blocksForSave
        const sanitized = blocksForSave.find(b => b.id === id) || block;
        return [id, sanitized];
      })
    );

    const themeForSave = sanitizeThemeForSave(theme);
    const metaForSave = sanitizeMetaForSave(meta);
    const fullState = {
      blocksData: blocksDataForSave,
      layout: {
        desktop: desktopLayout,
        mobile: desktopLayout,
      },
      theme: themeForSave,
      meta: metaForSave,
      settings: { autoSaveEnabled, autoSaveDelayMs, applyThemeToHome }
    };

    try {
      // Optimized: Direct Server Action
      const res = await saveArtistPageLayout(device, fullState);

      if (!res?.success) {
        throw new Error('Erreur lors de la sauvegarde');
      }

      saveLocalBackup(blocks, meta);
      addToast('Sauvegardé avec succès', 'success');
      setDirty(false);
    } catch (err) {
      console.error(err);
      addToast('Erreur lors de la sauvegarde', 'error');
    } finally {
      setSaving(false);
    }
  }, [addToast, blocksData, desktopLayout, theme, meta, customizationEndpoint, autoSaveEnabled, autoSaveDelayMs, applyThemeToHome, saveLocalBackup, extractResponseError, sanitizeBlocksForSave, sanitizeMetaForSave, sanitizeThemeForSave]);





  // Auto-save (draft) après inactivité si des changements non enregistrés
  const autoSaveTimer = useRef<NodeJS.Timeout | null>(null);
  const lastContentIssuesRef = useRef<{ missingAlt: number; invalidUrls: number }>({ missingAlt: 0, invalidUrls: 0 });
  useEffect(() => {
    if (autoSaveTimer.current) clearTimeout(autoSaveTimer.current);
    if (!dirty || saving || !autoSaveEnabled) return;
    autoSaveTimer.current = setTimeout(async () => {
      try {
        const issues = analyzeBlockContent(blocks);
        if (issues.missingAlt.length > 0 && issues.missingAlt.length !== lastContentIssuesRef.current.missingAlt) {
          addToast(`${issues.missingAlt.length} image(s) sans texte alternatif personnalisé. Pensez à les décrire.`, 'warning');
        }
        if (issues.invalidUrls.length > 0 && issues.invalidUrls.length !== lastContentIssuesRef.current.invalidUrls) {
          addToast(`${issues.invalidUrls.length} lien(s) doivent être saisis en https://`, 'warning');
        }
        lastContentIssuesRef.current = {
          missingAlt: issues.missingAlt.length,
          invalidUrls: issues.invalidUrls.length,
        };
        setAutoSaving(true);
        const blocksForSave = sanitizeBlocksForSave(blocks);
        const themeForSave = sanitizeThemeForSave(theme);
        const metaForSave = sanitizeMetaForSave(meta);
        const res = await fetch(customizationEndpoint, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ blocks: blocksForSave, theme: themeForSave, meta: metaForSave, settings: { autoSaveEnabled, autoSaveDelayMs, applyThemeToHome } }),
        });
        if (res.ok) {
          setDirty(false);
          setLastAutoSavedAt(new Date());
          setLiveStatus('Auto-enregistré');
          saveLocalBackup(blocksForSave, metaForSave);
        }
      } catch { }
      finally {
        try { saveLocalBackup(sanitizeBlocksForSave(blocks), sanitizeMetaForSave(meta)); } catch { }
        setAutoSaving(false);
      }
    }, Math.max(1000, Number(autoSaveDelayMs) || 8000));
    return () => { if (autoSaveTimer.current) clearTimeout(autoSaveTimer.current); };
  }, [blocks, theme, meta, dirty, saving, autoSaveEnabled, autoSaveDelayMs, applyThemeToHome, customizationEndpoint, saveLocalBackup, sanitizeBlocksForSave, sanitizeMetaForSave, sanitizeThemeForSave, analyzeBlockContent, addToast]);

  const [publishing, setPublishing] = useState(false);
  const [showAltGuard, setShowAltGuard] = useState(false);
  const [overrideAltGuard, setOverrideAltGuard] = useState(false);
  const [openingPreview, setOpeningPreview] = useState(false);
  const [showPreviewMenu, setShowPreviewMenu] = useState(false);
  const [previewLinks, setPreviewLinks] = useState<{ desktop?: string; mobile?: string } | null>(null);
  const previewMenuRef = useRef<HTMLDivElement | null>(null);

  const ensurePreviewLinks = async () => {
    const key = (pageKey || 'profile').toLowerCase();
    const res = await fetch(`/api/artist/preview-token/${encodeURIComponent(key)}`);
    if (!res.ok) {
      const detail = await extractResponseError(res);
      throw new Error(detail || 'Impossible de générer le lien de prévisualisation');
    }
    const data = await res.json();
    const desktop = typeof data.desktopPreviewUrl === 'string' ? data.desktopPreviewUrl : typeof data.previewUrl === 'string' ? data.previewUrl : undefined;
    const mobile = typeof data.mobilePreviewUrl === 'string' ? data.mobilePreviewUrl : undefined;
    if (!desktop) {
      throw new Error('Lien de prévisualisation indisponible');
    }
    setPreviewLinks({ desktop, mobile });
  };

  const handleTogglePreviewMenu = async () => {
    if (showPreviewMenu) {
      setShowPreviewMenu(false);
      return;
    }
    try {
      setOpeningPreview(true);
      if (!previewLinks) {
        await ensurePreviewLinks();
      }
      setShowPreviewMenu(true);
    } catch (e) {
      const message = e instanceof Error ? e.message : 'Erreur prévisualisation';
      addToast(message, 'error');
      setPreviewLinks(null);
    } finally {
      setOpeningPreview(false);
    }
  };

  const openPreviewWindow = (url: string, mode: 'desktop' | 'mobile') => {
    try {
      if (mode === 'mobile') {
        window.open(url, '_blank', 'noopener,width=428,height=926');
      } else {
        window.open(url, '_blank', 'noopener');
      }
    } catch {
      addToast('Impossible d’ouvrir la prévisualisation', 'error');
    }
  };

  const copyPreviewLink = async (url: string) => {
    try {
      await navigator.clipboard.writeText(url);
      addToast('Lien de prévisualisation copié', 'success');
    } catch {
      addToast('Copie du lien impossible sur ce navigateur', 'error');
    }
  };

  useEffect(() => {
    if (!showPreviewMenu) return;
    const handleClickOutside = (event: MouseEvent) => {
      if (!previewMenuRef.current) return;
      if (previewMenuRef.current.contains(event.target as Node)) return;
      setShowPreviewMenu(false);
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, [showPreviewMenu]);
  const titleInputRef = useRef<HTMLInputElement>(null);

  const handlePublish = async (forceOverride = false) => {
    setPublishing(true);
    try {
      if ((isBanner || isPoster) && dimensionErrors.length > 0) {
        addToast('Ajustez votre canevas : il dépasse les dimensions imposées.', 'error');
        setLiveAssertive('Publication bloquée : le canevas dépasse les dimensions autorisées.');
        setPublishing(false);
        return;
      }
      // Check guard unless overridden by state OR explicit argument
      if (altSummary.total > 0 && !overrideAltGuard && !forceOverride) {
        setShowAltGuard(true);
        setPublishing(false);
        return;
      }

      // Check for Title (UX Improvement)
      if (!isBanner && !isPoster && (!meta.title || meta.title.trim().length === 0)) {
        addToast(
          'Un titre est requis pour publier.',
          'error',
          6000,
          {
            label: 'Renseigner',
            onClick: () => {
              if (titleInputRef.current) {
                titleInputRef.current.focus();
                titleInputRef.current.classList.add('ring-2', 'ring-red-500', 'rounded');
                setTimeout(() => titleInputRef.current?.classList.remove('ring-2', 'ring-red-500', 'rounded'), 2000);
              }
            }
          }
        );
        setLiveAssertive('Publication bloquée : titre manquant.');
        setPublishing(false);
        // Focus the title input immediately as well
        if (titleInputRef.current) {
          titleInputRef.current.focus();
          titleInputRef.current.classList.add('ring-2', 'ring-red-500', 'rounded');
          setTimeout(() => titleInputRef.current?.classList.remove('ring-2', 'ring-red-500', 'rounded'), 2000);
        }
        return;
      }

      const blocksForSave = sanitizeBlocksForSave(blocks);
      const themeForSave = sanitizeThemeForSave(theme);
      const metaForSave = sanitizeMetaForSave(meta);
      const res = await fetch(customizationEndpoint, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'publish', blocks: blocksForSave, theme: themeForSave, meta: metaForSave, settings: { autoSaveEnabled, autoSaveDelayMs, applyThemeToHome } }),
      });
      if (!res.ok) {
        const detail = await extractResponseError(res);
        throw new Error(detail || `Échec de la publication (${res.status})`);
      }
      addToast('Page publiée', 'success');
      setPublicationStatus('published');
      setDirty(false);
      setLiveStatus('Page publiée');
    } catch (err: any) {
      addToast(`Erreur lors de la publication: ${err.message}`, 'error');
      setLiveAssertive(`Erreur lors de la publication: ${err.message}`);
    } finally {
      setPublishing(false);
      setOverrideAltGuard(false);
    }
  };
  // Composant interne pour un bloc déplaçable
  const SortableItem = ({ block, idx }: { block: Block; idx: number }) => {
    const { attributes, listeners, setNodeRef, transform, transition } = useSortable({ id: block.id, data: { type: 'root', index: idx } });
    const style: React.CSSProperties = {
      transform: CSS.Translate.toString(transform),
      transition,
      // touchAction: 'none', // Moved to Handle
      isolation: 'isolate',
      // Visibility per device
      // display: device === 'desktop' ... removed (always visible)
      // Ensure full width on mobile for vertical stacking
      width: device === 'mobile' ? '100%' : undefined,
    };
    return (
      <div
        ref={(el) => { setNodeRef(el); blockRefs.current[block.id] = el; }}
        style={style}
        {...attributes}
        // Listener removed from root to allow scroll/interaction
        className="w-full cms-card-item relative group" // Added relative group for handle positioning
        role="listitem"
        aria-label={`Bloc ${idx + 1} sur ${blocks.length} : ${block.type}`}
        tabIndex={0}
        onKeyDown={(e) => {
          // ... (Keep existing keyboard logic) ...
          const key = e.key;
          const isEditableTarget = () => {
            const t = e.target as HTMLElement | null;
            const tag = (t?.tagName || '').toLowerCase();
            return tag === 'input' || tag === 'textarea' || (t?.isContentEditable ?? false);
          };
          if (isEditableTarget()) return;
          if (key === 'Enter' || key === ' ') {
            e.preventDefault();
            setSelectedChild(null);
            setSelectedIndex(idx);
            setTimeout(() => inspectorContainerRef.current?.focus(), 0);
          } else if (key === 'Delete' || key === 'Backspace') {
            e.preventDefault();
            removeBlock(idx);
          } else if (key === 'ArrowDown') {
            e.preventDefault();
            const nextIdx = Math.min(blocks.length - 1, idx + 1);
            const nextId = blocks[nextIdx]?.id;
            if (nextId) {
              setSelectedIndex(nextIdx);
              setNextFocusBlockId(nextId);
            }
          } else if (key === 'ArrowUp') {
            e.preventDefault();
            const prevIdx = Math.max(0, idx - 1);
            const prevId = blocks[prevIdx]?.id;
            if (prevId) {
              setSelectedIndex(prevIdx);
              setNextFocusBlockId(prevId);
            }
          } else if ((key === 'ArrowDown' || key === 'ArrowUp') && e.shiftKey) {
            e.preventDefault();
          } else if (e.shiftKey && key === 'ArrowDown') {
            e.preventDefault();
            const oldIndex = idx;
            const newIndex = Math.min(blocks.length - 1, idx + 1);
            if (newIndex !== oldIndex) {
              setBlocks(prev => arrayMove(prev, oldIndex, newIndex));
              setSelectedIndex(newIndex);
              setNextFocusBlockId(block.id);
              setLiveStatus('Bloc déplacé vers le bas');
            }
          } else if (e.shiftKey && key === 'ArrowUp') {
            e.preventDefault();
            const oldIndex = idx;
            const newIndex = Math.max(0, idx - 1);
            if (newIndex !== oldIndex) {
              setBlocks(prev => arrayMove(prev, oldIndex, newIndex));
              setSelectedIndex(newIndex);
              setNextFocusBlockId(block.id);
              setLiveStatus('Bloc déplacé vers le haut');
            }
          }
        }}
      >
        <div id={`blk-${block.id}`} className={`relative ${viewMode === 'edit' ? (selectedIndex === idx ? 'ring-2 ring-blue-500 rounded pl-8' : 'pl-8') : ''}`}>
          {viewMode === 'edit' && (
            <>
              {/* Drag Handle - Always visible in edit mode on mobile, or on hover desktop */}
              <button
                className="absolute top-1/2 left-1 -translate-y-1/2 z-30 cursor-grab active:cursor-grabbing p-3 rounded-full bg-white/80 shadow-sm border border-gray-200 text-gray-500 hover:text-gray-800 transition touch-none"
                style={{ touchAction: 'none' }}
                {...listeners}
                title="Déplacer"
              >
                <svg width="12" height="24" viewBox="0 0 12 24" className="w-5 h-8 opacity-70">
                  <circle cx="4" cy="4" r="1.5" fill="currentColor" />
                  <circle cx="8" cy="4" r="1.5" fill="currentColor" />
                  <circle cx="4" cy="12" r="1.5" fill="currentColor" />
                  <circle cx="8" cy="12" r="1.5" fill="currentColor" />
                  <circle cx="4" cy="20" r="1.5" fill="currentColor" />
                  <circle cx="8" cy="20" r="1.5" fill="currentColor" />
                </svg>
              </button>

              <div
                className="absolute top-2 right-2 z-10 flex space-x-1"
                onPointerDown={e => e.stopPropagation()}
              >
                {/* Bouton dupliquer */}
                <button
                  type="button"
                  onClick={() => duplicateBlock(idx)}
                  title="Dupliquer"
                  aria-label="Dupliquer le bloc"
                  className="w-6 h-6 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full shadow text-gray-600 hover:text-gray-800 transition"
                >
                  ⎘
                </button>
                {/* Bouton supprimer */}
                <button
                  type="button"
                  onClick={() => removeBlock(idx)}
                  title="Supprimer"
                  aria-label="Supprimer le bloc"
                  className="w-6 h-6 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full shadow text-red-600 hover:text-red-800 transition"
                >
                  ×
                </button>
                {/* Bouton éditer */}
                <button
                  type="button"
                  onClick={viewMode === 'edit' ? (() => { setSelectedChild(null); setSelectedIndex(idx); }) : undefined}
                  title="Éditer"
                  aria-label="Éditer le bloc"
                  className="w-6 h-6 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full shadow text-blue-600 hover:text-blue-800 transition"
                >
                  ✎
                </button>
              </div>
            </>
          )}
          {viewMode === 'edit'
            ? renderBlock(block, idx)
            : renderPreviewBlock(block, idx)}
          {(() => { const css = [buildHoverCSS(block)].filter(Boolean).join('\n'); return css ? <style dangerouslySetInnerHTML={{ __html: css }} /> : null })()}
        </div>
      </div>
    );
  };
  /**
   * Sortable item for children inside a container
   */
  const ContainerSortableItem = ({ parentIndex, parentId, child, childIndex }: { parentIndex: number; parentId: string; child: Block; childIndex: number }) => {
    const { attributes, listeners, setNodeRef, transform, transition } = useSortable({
      id: child.id,
      data: { type: 'container-child', parentIndex, childIndex },
    });
    const cs = child.style || {};
    const js = (cs.canvasAlign === 'center') ? 'center' : (cs.canvasAlign === 'right') ? 'end' : 'start';
    const style: React.CSSProperties = {
      transform: CSS.Transform.toString(transform),
      transition,
      justifySelf: js,
      ...(cs.width ? { width: cs.width } : {}),
      ...(cs.zIndex ? { zIndex: cs.zIndex } : {}),
    } as React.CSSProperties;
    return (
      <div
        ref={setNodeRef}
        style={style}
        {...attributes}
        {...listeners}
        className="border border-gray-200 p-2"
        data-container-index={parentIndex}
        data-child-id={child.id}
        onClick={(e) => {
          if (viewMode === 'edit') {
            e.stopPropagation();
            e.nativeEvent.stopImmediatePropagation();
            setSelectedIndex(parentIndex); // Ensure parent is active context
            setSelectedChild({ parentId, childId: child.id });
          }
        }}
      >
        <div className="relative mt-2">
          <div className="absolute top-0 right-0 z-10 flex space-x-1" onPointerDown={e => { e.stopPropagation(); e.nativeEvent.stopImmediatePropagation(); }}>
            <button
              type="button"
              onClick={e => { e.stopPropagation(); removeBlockFromContainer(parentIndex, parentId, childIndex); }}
              title="Supprimer"
              aria-label="Supprimer le bloc"
              className="w-5 h-5 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full text-red-600 hover:text-red-800 transition"
            >×</button>
            <button
              type="button"
              onClick={e => { e.stopPropagation(); setSelectedChild({ parentId, childId: child.id }); }}
              title="Éditer"
              aria-label="Éditer le bloc"
              className="w-5 h-5 flex items-center justify-center bg-white bg-opacity-75 hover:bg-opacity-100 rounded-full text-blue-600 hover:text-blue-800 transition"
            >✎</button>
            {/* Poignée de déplacement vers le canvas supprimée (utilisez l'inspecteur) */}
          </div>
          <div onClick={e => { e.stopPropagation(); setSelectedChild({ parentId, childId: child.id }); }}>
            {renderBlock(child, parentIndex, true, viewMode)}
          </div>
        </div>
      </div>
    );
  };

  // Keyboard shortcuts: Undo/Redo

  // Focus the inspector when a block (or child) is selected

  // Keyboard nudge for absolute-positioned block: arrows = 1px, Shift+arrows = 10px

  // After structural changes, move focus to requested block if any

  // Auto-start tour once for new users (no step persistence)
  useEffect(() => {
    try {
      const done = window.localStorage.getItem('cmsTourDone');
      if (!done) {
        setTutorialStep(0);
        setShowTutorial(true);
      }
    } catch { }
  }, []);

  // Escape to close tour

  // Animation state for tour bubble/highlight
  const [tourAnim, setTourAnim] = useState(false);
  useEffect(() => {
    if (!showTutorial) return;
    setTourAnim(false);
    requestAnimationFrame(() => setTourAnim(true));
  }, [showTutorial, tutorialStep]);

  const endTour = () => {
    try { window.localStorage.setItem('cmsTourDone', '1'); } catch { }
    setShowTutorial(false);
  };


  // Local backup key (per page)
  // Offer restoring a local backup when there is no server content
  useEffect(() => {
    try {
      const raw = window.localStorage.getItem(localKey);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      const hasServer = Array.isArray(init?.blocks) && (init.blocks as any[]).length > 0;
      if (!hasServer && parsed && Array.isArray(parsed.blocks)) {
        addToast(
          'Un brouillon local a été trouvé pour cette page.',
          'info',
          Infinity,
          {
            label: 'Restaurer',
            onClick: () => {
              try {
                const raw = window.localStorage.getItem(localKey);
                if (raw) {
                  const json = JSON.parse(raw);
                  applyImportedContent(json);
                  addToast('Brouillon local restauré', 'success');
                }
              } catch { }
            }
          },
          {
            label: 'Ignorer',
            onClick: () => {
              try { window.localStorage.removeItem(localKey); } catch { }
            }
          }
        );
      }
    } catch { }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [localKey]);

  const applyImportedContent = (payload: any) => {
    const nb = Array.isArray(payload?.blocks) ? payload.blocks : [];
    const nt = payload?.theme || defaultTheme;
    const nm = payload?.meta || { title: '', description: '', canonicalUrl: '' };

    replaceContent({ blocks: nb, theme: nt, meta: nm });
  };


  const handleExport = () => {
    try {
      const data = { blocks, theme: sanitizeThemeForSave(theme), meta, settings: { autoSaveEnabled, autoSaveDelayMs, applyThemeToHome } };
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${(pageKey || 'profile')}-draft.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch { }
  };
  const handleImportClick = () => { try { fileInputRef.current?.click(); } catch { } };
  const handleImportFile = (e: React.ChangeEvent<HTMLInputElement>) => {
    const f = e.target.files && e.target.files[0];
    if (!f) return;
    const reader = new FileReader();
    reader.onload = () => {
      try {
        const text = String(reader.result || '');
        const json = JSON.parse(text);
        applyImportedContent(json);
        addToast('Contenu importé', 'success');
      } catch {
        addToast('Fichier invalide', 'error');
      } finally {
        try { (e.target as any).value = ''; } catch { }
      }
    };
    reader.readAsText(f);
  };



  // Contexte d'affichage selon la page (profil / affiche / bandeau)
  const [showAltPanel, setShowAltPanel] = useState(false);
  const openAltPanel = useCallback(() => setShowAltPanel(true), [setShowAltPanel]);
  const [showQuickSectionsModal, setShowQuickSectionsModal] = useState(false);
  const [quickPreviewSection, setQuickPreviewSection] = useState<{
    key: string;
    label: string;
    description: string;
    accentColor?: string;
    familyLabel: string;
    blocks: Block[];
  } | null>(null);

  const textContrastLabel = textContrastRatio !== null ? textContrastRatio.toFixed(2) : null;
  const overlayContrastLabel = overlayContrastRatio !== null ? overlayContrastRatio.toFixed(2) : null;
  const publishWarnings = React.useMemo<PublishWarning[]>(() => {
    const warnings: PublishWarning[] = [];
    if (altSummary.total > 0) {
      warnings.push({
        id: 'alt',
        message: `${altSummary.total} image(s) sans texte alternatif personnalisé.`,
        description: 'Ajoutez un ALT descriptif pour renforcer l’accessibilité et le SEO.',
        actionLabel: 'Compléter les ALT',
        action: openAltPanel,
      });
    }
    if (altSummary.mediaIssues.length > 0) {
      warnings.push({
        id: 'media-a11y',
        message: `${altSummary.mediaIssues.length} média(s) nécessitent un réglage accessibilité.`,
        description: 'Activez les contrôles, ajoutez un titre ou une légende pour vos vidéos et intégrations.',
        actionLabel: 'Centre accessibilité',
        action: openAltPanel,
      });
    }
    if (contentIssues.invalidUrls.length > 0) {
      warnings.push({
        id: 'links',
        message: `${contentIssues.invalidUrls.length} lien(s) doivent être saisis en https://`,
        description: 'Les liens non sécurisés sont bloqués lors de la publication pour protéger vos visiteurs.',
      });
    }
    if (textContrastRatio !== null && textContrastRatio < 4.5) {
      warnings.push({
        id: 'contrast-text',
        message: textContrastLabel
          ? `Contraste texte/fond ${textContrastLabel}:1 insuffisant.`
          : 'Contraste texte/fond insuffisant.',
        description: 'Ajustez votre palette pour atteindre un contraste ≥ 4.5 (WCAG AA).',
        actionLabel: 'Réglages du thème',
        action: openThemeTuning,
      });
    }
    if (overlayContrastRatio !== null && overlayContrastRatio < 4.5) {
      warnings.push({
        id: 'contrast-overlay',
        message: overlayContrastLabel
          ? `Overlay vs texte ${overlayContrastLabel}:1 trop faible.`
          : 'Overlay vs texte trop faible.',
        description: 'Renforcez l’opacité ou la couleur de l’overlay pour préserver la lisibilité.',
        actionLabel: 'Réglages du thème',
        action: openThemeTuning,
      });
    }
    return warnings;
  }, [
    altSummary.total,
    altSummary.mediaIssues.length,
    contentIssues.invalidUrls.length,
    textContrastRatio,
    textContrastLabel,
    overlayContrastRatio,
    overlayContrastLabel,
    openAltPanel,
    openThemeTuning,
  ]);
  const closeQuickSectionsModal = useCallback(() => {
    setShowQuickSectionsModal(false);
    setQuickPreviewSection(null);
  }, []);

  const {
    goToBlock,
    toggleFocusMode,
  } = useCanvasInteraction({
    viewMode,
    blocks,
    setBlocks,
    selectedIndex,
    setSelectedIndex,
    selectedChild,
    setSelectedChild,
    inspectorContainerRef,
    themeContainerRef,
    blockRefs,
    handleSave,
    undo,
    redo,
    nextFocusBlockId,
    setNextFocusBlockId,
    showTutorial,
    endTour,
    showQuickSectionsModal,
    closeQuickSectionsModal,
    quickPreviewSection,
    setQuickPreviewSection,
    findBlockById,
    setShowThemeModal,
    setShowPalette,
    setShowInspector,
    focusModeActive,
  });

  const togglePalette = React.useCallback(() => {
    setShowPalette(prev => !prev);
  }, [setShowPalette]);

  const toggleInspector = React.useCallback(() => {
    if (viewMode !== 'edit') return;
    setShowInspector(prev => !prev);
  }, [setShowInspector, viewMode]);


  useEffect(() => {
    if (!showQuickSectionsModal) {
      setQuickPreviewSection(null);
    }
  }, [showQuickSectionsModal]);
  const updateAltTextForIssue = useCallback(
    (issueId: string, nextAlt: string) => {
      const issue = altSummary.items[issueId];
      if (!issue || !issue.targetBlockId) return;
      if (issue.kind === 'image') {
        updateBlockById(issue.targetBlockId, current => {
          if (!current || current.type !== 'image') return current;
          return { ...current, altText: nextAlt, decorative: false };
        });
      } else {
        updateBlockById(issue.targetBlockId, current => {
          if (!current || current.type !== 'gallery') return current;
          const gallery = current as GalleryBlock;
          const images = Array.isArray(gallery.images) ? [...gallery.images] : [];
          const nextImages = images.map((img: GalleryImage, idx: number) => {
            const matches =
              (issue.imageId && img.id === issue.imageId) ||
              (!issue.imageId && idx === issue.imageIndex);
            if (!matches) return img;
            return { ...img, altText: nextAlt, decorative: false };
          });
          return { ...gallery, images: nextImages };
        });
      }
    },
    [altSummary, updateBlockById],
  );

  const markIssueDecorative = useCallback(
    (issueId: string) => {
      const issue = altSummary.items[issueId];
      if (!issue || !issue.targetBlockId) return;
      if (issue.kind === 'image') {
        updateBlockById(issue.targetBlockId, current => {
          if (!current || current.type !== 'image') return current;
          return { ...current, altText: '', decorative: true };
        });
      } else {
        updateBlockById(issue.targetBlockId, current => {
          if (!current || current.type !== 'gallery') return current;
          const gallery = current as GalleryBlock;
          const images = Array.isArray(gallery.images) ? [...gallery.images] : [];
          const nextImages = images.map((img: GalleryImage, idx: number) => {
            const matches =
              (issue.imageId && img.id === issue.imageId) ||
              (!issue.imageId && idx === issue.imageIndex);
            if (!matches) return img;
            return { ...img, altText: '', decorative: true };
          });
          return { ...gallery, images };
        });
      }
    },
    [altSummary, updateBlockById],
  );



  // Spacing helpers
  const normPx = (v: unknown, def = 16): string => {
    if (v === null || v === undefined || v === '') return `${def}px`;
    const s = String(v).trim();
    if (/^\d+$/.test(s)) return `${s}px`;
    if (/^\d+(px|rem|em|%)$/.test(s)) return s;
    const n = Number(s);
    return isNaN(n) ? `${def}px` : `${n}px`;
  };


  const closePreviewMenu = React.useCallback(() => {
    setShowPreviewMenu(false);
  }, [setShowPreviewMenu]);

  const closeMoreMenu = React.useCallback(() => {
    setShowMoreMenu(false);
  }, [setShowMoreMenu]);

  const handleSaveLocalDraft = React.useCallback(() => {
    try {
      const blocksForSave = sanitizeBlocksForSave(blocks);
      const metaForSave = sanitizeMetaForSave(meta);
      saveLocalBackup(blocksForSave, metaForSave);
      addToast('Brouillon sauvegardé localement', 'success');
    } catch (error: any) {
      addToast(error?.message ? `Erreur: ${error.message}` : 'Impossible de sauvegarder localement', 'error');
    }
  }, [addToast, blocks, meta, sanitizeBlocksForSave, sanitizeMetaForSave, saveLocalBackup]);


  const workspaceClassName = React.useMemo(() => {
    if (isBanner) {
      const base = 'relative mx-auto hidden lg:flex w-full flex-1 flex-col gap-6 px-3 pt-6 pb-16 md:px-6 md:pt-8 lg:px-8';
      const grid = inspectorPaneActive
        ? 'xl:grid xl:grid-cols-[minmax(0,0.72fr)_minmax(320px,0.28fr)] xl:grid-rows-[auto_auto] xl:items-start xl:gap-8'
        : 'xl:grid xl:grid-cols-[minmax(0,0.78fr)_minmax(320px,0.22fr)] xl:items-start xl:gap-8';
      return `${base} ${grid}`.trim();
    }
    const hasSidePanels = showPalette || inspectorPaneActive;
    // Reduced padding-top to pt-20 from pt-32 per user feedback
    return `relative mx-auto hidden lg:flex w-full max-w-[1440px] flex-1 overflow-hidden px-3 pt-20 pb-12 md:px-6 md:pt-24 lg:px-8 ${hasSidePanels ? 'gap-4 lg:gap-6' : ''}`;

  }, [isBanner, inspectorPaneActive, showPalette]);
  const workspaceStyle = React.useMemo<React.CSSProperties | undefined>(() => {
    if (!isBanner) return undefined;
    return { maxWidth: `min(100%, ${BANNER_DESIGN_WIDTH + 520}px)` };
  }, [BANNER_DESIGN_WIDTH, isBanner]);
  const canvasWrapperClasses = React.useMemo(() => {
    if (isBanner) {
      return 'flex flex-1 min-w-0 flex-col gap-6 transition-all duration-200 xl:items-start';
    }
    // Preview Mode OR Focus Mode: Full Width
    if (isFocusMode || viewMode === 'preview') {
      return 'flex flex-1 min-w-0 flex-col transition-all duration-300 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-200 w-full max-w-none px-0';
    }
    return [
      'flex flex-1 min-w-0 flex-col transition-all duration-200 overflow-y-auto scrollbar-thin scrollbar-thumb-gray-200',
      showPalette && inspectorPaneActive ? 'xl:max-w-4xl' : 'xl:max-w-5xl',
      !showPalette && !inspectorPaneActive ? 'mx-auto' : '',
    ]
      .filter(Boolean)
      .join(' ');
  }, [isBanner, inspectorPaneActive, showPalette, isFocusMode, viewMode]);

  const editorStateValue = React.useMemo<EditorState>(() => ({
    // State exposed by useEditorBlocks
    blocks,
    blocksData,
    desktopLayout,
    theme,
    meta,
    isDirty: dirty,
    canUndo,
    canRedo,

    // Selection
    selectedChild,
    selectedIndex,

    // UI Props
    viewMode,
    showPalette,
    showInspector,
    paletteView,
    focusModeActive,

    // Canvas State
    canvasWidth,
    debugOutlines,

    // Page Info
    pageKey: pageKey || 'profile',
    isBanner,
    isPoster,
    device,

    // Status
    publicationStatus,
    publishing: (typeof publishing !== 'undefined' ? publishing : saving),
    autoSaving,
    liveStatus,
    saving,
    suspendHistoryRef, // Ref is stable but often read in render if used as logic flag - but better as State for now

    // Data / Resources
    artistData,
    previewUrl,
    oeuvreOptions: initialOeuvreOptions,
    families: filteredFamilies,
    blockTypes,
    structurePreview: quickPreviewSection,
    blockRefs,
  }), [
    blocks, blocksData, desktopLayout, theme, meta, dirty,
    canUndo, canRedo,
    selectedChild, selectedIndex,
    viewMode, showPalette, showInspector, paletteView,
    focusModeActive,
    canvasWidth, debugOutlines,
    pageKey, isBanner, isPoster, device,
    publicationStatus, publishing, autoSaving, liveStatus, saving,
    artistData, previewUrl, initialOeuvreOptions, filteredFamilies, blockTypes,
    quickPreviewSection, blockRefs
  ]);

  const editorActionsValue = React.useMemo<EditorActions>(() => ({
    // Setters
    setTheme,
    setMeta,
    setDirty,
    undo,
    redo,
    resetHistory,
    addBlock,
    removeBlock,
    setBlocks,
    duplicateBlock,
    updateBlock,
    moveBlock,
    replaceContent,
    setSelectedChild,
    setSelectedIndex,

    setViewMode,
    setShowPalette,
    setShowInspector,
    setPaletteView,
    toggleFocusMode,

    setCanvasWidth,
    setDebugOutlines,

    setDevice,

    onPublish: handlePublish,
    save: handleSave,

    sanitizeRichText,
    blockRefs,
    handlePaletteDragStart: handleDragStart,
    goToBlock,
    addQuickSection,
    setStructurePreview: setQuickPreviewSection,
    buildSectionBlocks: buildSectionBlocks,

    setBlocksData,
    setDesktopLayout,
    reorderBlocks,
  }), [
    setTheme, setMeta, setDirty, undo, redo, resetHistory, addBlock, removeBlock, setBlocks, duplicateBlock, updateBlock, moveBlock, replaceContent,
    setSelectedChild, setSelectedIndex,
    setViewMode, setShowPalette, setShowInspector, setPaletteView, toggleFocusMode,
    setCanvasWidth, setDebugOutlines,
    setDevice,
    handlePublish, handleSave,
    sanitizeRichText, handleDragStart, goToBlock, addQuickSection, setQuickPreviewSection, buildSectionBlocks,
    setBlocksData, setDesktopLayout, reorderBlocks
  ]);

  return (
    <EditorActionsContext.Provider value={editorActionsValue}>
      <EditorStateContext.Provider value={editorStateValue}>
        <div className={`flex flex-col h-full bg-gradient-to-br from-slate-50 via-white to-slate-100 text-gray-900 transition-opacity duration-200 ${mounted ? 'opacity-100' : 'opacity-0'} antialiased`}>
          <ArtworkCreateModal
            open={showArtworkModal}
            onClose={handleCloseArtworkModal}
            categories={artworkCategories}
            onCreated={handleArtworkCreated}
          />

          {showAltGuard && (
            <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-testid="alt-guard-modal">
              <div className="bg-white rounded shadow-lg p-4 w-[480px] max-w-[95vw]">
                <h3 className="text-lg font-semibold mb-2">Accessibilité à compléter</h3>
                <p className="text-sm text-gray-700 mb-3">{altSummary.total} texte(s) alternatif(s) manquant(s). Veuillez les renseigner pour optimiser l’accessibilité et le SEO.</p>
                <div className="flex items-center justify-end gap-2">
                  <button className="px-3 py-1.5 text-sm rounded bg-white border" onClick={() => { setShowAltGuard(false); setShowAltPanel(true); }}>Voir les blocs</button>
                  <button className="px-3 py-1.5 text-sm rounded bg-gray-100" onClick={() => setShowAltGuard(false)}>Annuler</button>
                  <button className="px-3 py-1.5 text-sm rounded bg-green-600 text-white" onClick={async () => { setShowAltGuard(false); setOverrideAltGuard(true); await handlePublish(true); }}>Publier quand même</button>
                </div>
              </div>
            </div>
          )}

          <div className="relative z-30">
            {/* Live regions for screen readers */}
            <div className="sr-only" role="status" aria-live="polite">
              {liveStatus}
            </div>
            <div className="sr-only" role="alert" aria-live="assertive">
              {liveAssertive}
            </div>

            <div className="mx-auto w-full max-w-[1440px] px-3 py-1.5 md:px-6 lg:px-8">
              <EditorUnifiedMenu
                modeRef={modeRef}
                onOpenTemplateSelector={() => setShowTemplateSelector(true)}
                saveRef={saveRef}
                publishRef={publishRef}
                onTogglePreviewMenu={handleTogglePreviewMenu}
                onClosePreviewMenu={closePreviewMenu}
                openingPreview={openingPreview}
                showPreviewMenu={showPreviewMenu}
                previewMenuRef={previewMenuRef}
                previewLinks={previewLinks}
                openPreviewWindow={openPreviewWindow}
                copyPreviewLink={copyPreviewLink}
                showMoreMenu={showMoreMenu}
                onToggleMoreMenu={() => setShowMoreMenu(s => !s)}
                onCloseMoreMenu={closeMoreMenu}
                onSelectThemeMode={() => setViewMode('theme')}
                onOpenAltPanel={openAltPanel}
                altSummaryCount={altSummary.total + altSummary.mediaIssues.length}

                onExport={handleExport}
                onImport={handleImportClick}
                onSaveLocalDraft={handleSaveLocalDraft}
                onResetGenericAlt={resetGenericAltAll}
                canAddOeuvre={pageKey === 'poster' || pageKey === 'banner'}
                onAddOeuvre={() => handleAddBlock('oeuvre')}
                canCreateArtwork
                onOpenArtworkModal={handleOpenArtworkModal}
                notify={addToast}
                // pageNavigation={pageNavigation} // Removed
                lastPublishedAt={lastPublishedAt}
                canEditTitle={true}
                metaTitle={meta.title}
                titleInputRef={titleInputRef}
                metaTitlePlaceholder={quickTitlePlaceholder}
                onChangeMetaTitle={value => setMeta(prev => ({ ...prev, title: value }))}
                publishWarnings={publishWarnings}
              />
            </div>
          </div>

          {showFeaturedPicker && (
            <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/40">
              <div className="bg-white w-[560px] max-w-[92vw] rounded shadow-lg p-4">
                <div className="flex items-center justify-between mb-2"><div className="font-semibold">Sélection en tête (max 2)</div><button onClick={() => setShowFeaturedPicker(false)} className="text-gray-500 hover:text-gray-700">×</button></div>
                <div className="grid grid-cols-2 gap-2 max-h-72 overflow-auto pr-1">
                  {oeuvreOptions.map(opt => (
                    <label key={opt.id} className="flex items-center gap-2 p-2 border rounded hover:bg-gray-50">
                      <input type="checkbox" checked={featuredSelection.includes(opt.id)} onChange={() => toggleFeatured(opt.id)} disabled={!featuredSelection.includes(opt.id) && featuredSelection.length >= 2} />
                      {opt.imageUrl ? <img src={opt.imageUrl} alt="" className="w-10 h-10 object-cover rounded" /> : <div className="w-10 h-10 bg-gray-200 rounded" />}
                      <span className="text-sm truncate" title={opt.title}>{opt.title}</span>
                    </label>
                  ))}
                  {oeuvreOptions.length === 0 && <div className="text-xs text-gray-500">Aucune œuvre disponible.</div>}
                </div>
                <div className="mt-3 flex items-center justify-end gap-2">
                  <button className="px-2 py-1 text-sm rounded border" onClick={() => { setFeaturedSelection([]); }}>Vider</button>
                  <button className="px-3 py-1.5 text-sm rounded bg-blue-600 text-white" disabled={featuredSelection.length === 0} onClick={() => { upsertFeaturedAfterHero(featuredSelection); setShowFeaturedPicker(false); }}>Appliquer</button>
                </div>
              </div>
            </div>
          )}
          {showQuickSectionsModal && (
            <div
              className="fixed inset-0 z-40 flex items-center justify-center bg-black/45 px-4 py-8"
              onMouseDown={closeQuickSectionsModal}
            >
              <div
                role="dialog"
                aria-modal="true"
                aria-labelledby="quick-sections-title"
                className="relative w-full max-w-4xl rounded-2xl bg-white shadow-2xl ring-1 ring-black/10"
                onMouseDown={event => event.stopPropagation()}
              >
                <div className="flex items-start justify-between gap-4 border-b border-gray-200 px-6 py-4">
                  <div>
                    <h2 id="quick-sections-title" className="text-lg font-semibold text-gray-900">Familles de sections rapides</h2>
                    <p className="mt-1 text-sm text-gray-500">
                      Choisissez une famille, puis insérez la section qui correspond à votre intention.
                    </p>
                  </div>
                  <button
                    type="button"
                    onClick={closeQuickSectionsModal}
                    className="rounded-full p-2 text-gray-500 transition hover:bg-gray-100 hover:text-gray-700"
                    aria-label="Fermer la sélection de sections rapides"
                  >
                    ×
                  </button>
                </div>
                <div className="max-h-[65vh] overflow-y-auto px-6 py-5 space-y-4">
                  <div className="border-b border-gray-100 pb-3">
                    <div className="flex flex-wrap gap-2">
                      {QUICK_SECTION_FILTERS.map(filter => {
                        const filterCounts = { [filter.value]: 99 }; // Mock count to fix build
                        const isActive = quickSectionFilter === filter.value;
                        const count = filterCounts[filter.value] ?? 0;
                        const disabled = filter.value !== 'all' && count === 0;
                        return (
                          <button
                            key={filter.value}
                            type="button"
                            disabled={disabled}
                            onClick={() => setQuickSectionFilter(filter.value)}
                            className={[
                              'inline-flex items-center gap-1 rounded-full px-3 py-1.5 text-xs font-medium transition',
                              isActive ? 'bg-blue-600 text-white shadow-sm shadow-blue-200' : 'bg-gray-100 text-gray-600 hover:bg-gray-200',
                              disabled ? 'opacity-50 cursor-not-allowed hover:bg-gray-100' : '',
                            ].join(' ')}
                          >
                            {filter.label}
                            <span className="text-[10px] font-semibold opacity-80">{count}</span>
                          </button>
                        );
                      })}
                    </div>
                  </div>
                  {filteredFamilies.length === 0 ? (
                    <div className="rounded-md border border-dashed border-gray-200 bg-gray-50 p-6 text-center text-sm text-gray-500">
                      {quickSectionFilter === 'all'
                        ? 'Aucun preset n’est disponible pour le moment.'
                        : 'Aucune section ne correspond à ce filtre. Essayez une autre catégorie.'}
                    </div>
                  ) : (
                    <>
                      {recommendedFamilyKey && filteredFamilies.some(f => f.key === recommendedFamilyKey) && (
                        <div className="rounded-lg border border-blue-200 bg-blue-50/70 px-4 py-3 text-xs sm:text-sm text-blue-800">
                          Suggestion&nbsp;: <span className="font-semibold">{filteredFamilies.find(f => f.key === recommendedFamilyKey)?.label}</span> semble compléter votre page actuelle.
                        </div>
                      )}
                      {filteredFamilies.map(family => {
                        const isExpanded = expandedQuickFamily === family.key;
                        return (
                          <div
                            key={family.key}
                            className={`rounded-xl ${family.isRecommended ? 'border border-blue-200 bg-blue-50/40 shadow-sm shadow-blue-100/60' : 'border border-gray-200 bg-white shadow-sm shadow-gray-100/40'}`}
                          >
                            <button
                              type="button"
                              onClick={() => setExpandedQuickFamily(isExpanded ? null : family.key)}
                              className={`flex w-full items-start justify-between gap-3 rounded-xl px-4 py-3 text-left transition focus:outline-none focus:ring-2 focus:ring-blue-500/40 ${family.isRecommended ? 'hover:bg-blue-50/80' : 'hover:bg-gray-50'}`}
                            >
                              <span className="flex items-start gap-3">
                                <span
                                  aria-hidden
                                  className="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full"
                                  style={{ backgroundColor: family.accentColor || '#2563eb' }}
                                />
                                <span>
                                  <span className="block text-sm font-semibold text-gray-800 flex items-center gap-2">
                                    {family.label}
                                    {family.isRecommended && (
                                      <span className="inline-flex items-center rounded-full border border-blue-200 bg-white px-2 py-0.5 text-[10px] font-medium text-blue-600">
                                        Recommandé
                                      </span>
                                    )}
                                  </span>
                                  <span className="mt-0.5 block text-[12px] leading-snug text-gray-500">{family.description}</span>
                                </span>
                              </span>
                              <ChevronDownIcon
                                className={`mt-1 h-4 w-4 text-gray-500 transition-transform ${isExpanded ? 'rotate-180' : ''}`}
                                strokeWidth={1.75}
                                aria-hidden
                              />
                            </button>
                            {isExpanded && (
                              <div className="border-t border-gray-100 px-4 py-3 space-y-3">
                                {family.sections.map((section: any) => {
                                  const thumbnailBlocks = buildSectionBlocks(section).slice(0, 2);
                                  return (
                                    <div
                                      key={section.key}
                                      className="rounded-lg border border-transparent px-3 py-2 transition hover:border-blue-200 hover:bg-blue-50/60 focus-within:ring-2 focus-within:ring-blue-500/30"
                                    >
                                      <div className="flex items-start gap-2">
                                        <span
                                          aria-hidden
                                          className="mt-1 h-1.5 w-6 flex-shrink-0 rounded-full"
                                          style={{ backgroundColor: section.accentColor || family.accentColor }}
                                        />
                                        <div>
                                          <div className="text-sm font-semibold text-gray-800">{section.label}</div>
                                          <div className="mt-1 text-[12px] leading-snug text-gray-500">{section.description}</div>
                                          {section.tips?.length ? (
                                            <div className="mt-1 text-[11px] text-gray-400">{section.tips.join(' • ')}</div>
                                          ) : null}
                                        </div>
                                      </div>
                                      <div className="mt-3 rounded-lg border border-gray-100 bg-white/80 p-2">
                                        {thumbnailBlocks.length > 0 ? (
                                          <div className="relative h-28 overflow-hidden rounded-md border border-gray-100 bg-white">
                                            <div
                                              className="pointer-events-none origin-top-left scale-[0.58] transform"
                                              style={{ width: '300px', padding: '0.5rem' }}
                                            >
                                              {thumbnailBlocks.map((previewBlock: Block, idx: number) => (
                                                <div key={previewBlock.id || idx} className="mb-3 last:mb-0">
                                                  {renderBlock(previewBlock, idx, true, 'preview')}
                                                </div>
                                              ))}
                                            </div>
                                          </div>
                                        ) : (
                                          <div className="py-6 text-center text-[11px] text-gray-400">Prévisualisation compacte indisponible pour cette section.</div>
                                        )}
                                      </div>
                                      <div className="mt-3 flex flex-wrap items-center gap-2">
                                        <button
                                          type="button"
                                          onClick={() => handlePreviewSection(family, section)}
                                          className="inline-flex items-center gap-1 rounded-md border border-gray-300 px-2.5 py-1 text-xs font-medium text-gray-700 transition hover:bg-gray-100"
                                        >
                                          <EyeIcon className="h-3.5 w-3.5" strokeWidth={1.75} aria-hidden />
                                          Prévisualiser
                                        </button>
                                        <button
                                          type="button"
                                          onClick={() => {
                                            if (isBanner) {
                                              openBannerTemplateDrawerStub({
                                                key: section.key,
                                                label: section.label,
                                                description: section.description,
                                                familyLabel: family.label,
                                                accentColor: section.accentColor || family.accentColor,
                                              });
                                              closeQuickSectionsModal();
                                            } else {
                                              addQuickSection(section.key);
                                              closeQuickSectionsModal();
                                            }
                                          }}
                                          className="inline-flex items-center gap-1 rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-blue-700"
                                        >
                                          <PlusIcon className="h-3.5 w-3.5" strokeWidth={2} aria-hidden />
                                          Insérer cette section
                                        </button>
                                      </div>
                                    </div>
                                  );
                                })}
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </>
                  )}
                </div>
              </div>
            </div>
          )}
          {quickPreviewSection && (
            <div
              className="fixed inset-0 z-50 flex items-center justify-center bg-black/55 px-4 py-8"
              onMouseDown={() => setQuickPreviewSection(null)}
            >
              <div
                role="dialog"
                aria-modal="true"
                aria-labelledby="quick-section-preview-title"
                className="relative w-full max-w-4xl rounded-2xl bg-white shadow-2xl ring-1 ring-black/10"
                onMouseDown={event => event.stopPropagation()}
              >
                <div className="flex items-start justify-between gap-4 border-b border-gray-200 px-6 py-4">
                  <div>
                    <p className="text-xs font-semibold uppercase tracking-wide text-gray-500">{quickPreviewSection.familyLabel}</p>
                    <h2 id="quick-section-preview-title" className="text-lg font-semibold text-gray-900 flex items-center gap-2">
                      <span
                        aria-hidden
                        className="h-2 w-2 rounded-full"
                        style={{ backgroundColor: quickPreviewSection.accentColor || '#2563eb' }}
                      />
                      {quickPreviewSection.label}
                    </h2>
                    <p className="mt-1 text-sm text-gray-500">{quickPreviewSection.description}</p>
                  </div>
                  <button
                    type="button"
                    onClick={() => setQuickPreviewSection(null)}
                    className="rounded-full p-2 text-gray-500 transition hover:bg-gray-100 hover:text-gray-700"
                    aria-label="Fermer l’aperçu de la section"
                  >
                    ×
                  </button>
                </div>
                <div className="max-h-[65vh] overflow-y-auto px-6 py-5">
                  <div
                    className="rounded-xl border border-gray-200 bg-white p-5 shadow-sm"
                    style={{
                      backgroundColor: theme.backgroundColor || '#ffffff',
                      color: theme.textColor || '#1f2937',
                      fontFamily: theme.bodyFont,
                    }}
                  >
                    <div className="space-y-4">
                      {quickPreviewSection.blocks.length === 0 ? (
                        <p className="text-sm text-gray-500">Prévisualisation indisponible pour cette section.</p>
                      ) : (
                        quickPreviewSection.blocks.map((previewBlock, idx) => (
                          <div key={(previewBlock as any).id || idx} className="last:mb-0">
                            {renderBlock(previewBlock, idx, true, 'preview')}
                          </div>
                        ))
                      )}
                    </div>
                  </div>
                </div>
                <div className="flex flex-wrap items-center justify-end gap-2 border-t border-gray-200 px-6 py-4">
                  <button
                    type="button"
                    onClick={() => setQuickPreviewSection(null)}
                    className="rounded-md border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-100"
                  >
                    Fermer
                  </button>
                  <button
                    type="button"
                    onClick={() => {
                      if (isBanner) {
                        openBannerTemplateDrawerStub({
                          key: quickPreviewSection.key,
                          label: quickPreviewSection.label,
                          description: quickPreviewSection.description,
                          familyLabel: quickPreviewSection.familyLabel,
                          accentColor: quickPreviewSection.accentColor,
                        });
                        setQuickPreviewSection(null);
                        closeQuickSectionsModal();
                      } else {
                        addQuickSection(quickPreviewSection.key);
                        closeQuickSectionsModal();
                      }
                    }}
                    className="inline-flex items-center gap-1 rounded-md bg-blue-600 px-3.5 py-1.5 text-sm font-semibold text-white transition hover:bg-blue-700"
                  >
                    <PlusIcon className="h-4 w-4" strokeWidth={2} aria-hidden />
                    Insérer cette section
                  </button>
                </div>
              </div>
            </div>
          )}
          <BannerTemplateDrawer
            open={isBannerTemplateDrawerOpen}
            draft={bannerTemplateDraft as any}
            selectedIndices={bannerTemplateSelection}
            hasSelection={bannerTemplateHasSelection}
            onToggleBlock={toggleBannerTemplateBlock}
            onSelectAll={selectAllBannerTemplateBlocks}
            onClearSelection={clearBannerTemplateSelection}
            onApplyAll={applyBannerTemplate}
            onMergeSelected={mergeBannerTemplate}
            onClose={closeBannerTemplateDrawer}
            renderPreviewBlock={renderPreviewBlock}
            currentBlockCount={blocks.length}
          />
          {/* Panneau récapitulatif ALT */}
          {postInsertChecklist && (
            <div className="fixed bottom-6 right-6 z-40 w-80 max-w-[90vw] rounded-xl border border-blue-200 bg-white shadow-xl shadow-blue-100/60">
              <div className="flex items-start justify-between gap-2 border-b border-blue-100 px-4 py-3">
                <div>
                  <p className="text-xs font-semibold uppercase tracking-wide text-blue-600">Checklist</p>
                  <p className="text-sm font-semibold text-gray-900">{postInsertChecklist.label}</p>
                </div>
                <button
                  type="button"
                  onClick={() => setPostInsertChecklist(null)}
                  className="rounded-full p-1 text-blue-500 transition hover:bg-blue-50"
                  aria-label="Fermer la checklist post-insertion"
                >
                  ×
                </button>
              </div>
              <div className="px-4 py-3 text-sm text-gray-700">
                <ul className="space-y-2">
                  {postInsertChecklist.steps.map((step, idx) => (
                    <li key={`${postInsertChecklist.sectionKey}-${idx}`} className="flex items-start gap-2">
                      <span
                        aria-hidden
                        className="mt-1 h-2 w-2 flex-shrink-0 rounded-full"
                        style={{ backgroundColor: postInsertChecklist.accentColor || '#2563eb' }}
                      />
                      <span>{step}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div className="flex items-center justify-end gap-2 border-t border-blue-100 px-4 py-3">
                <button
                  type="button"
                  onClick={() => setPostInsertChecklist(null)}
                  className="rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-blue-700"
                >
                  Checklist terminée
                </button>
              </div>
            </div>
          )}
          {showAltPanel && (
            <div className="fixed top-16 right-4 z-40 w-[400px] flex flex-col max-h-[calc(100vh-6rem)] rounded-2xl border border-gray-200 bg-white shadow-2xl overflow-hidden ring-1 ring-black/5 animate-in slide-in-from-right-4 fade-in duration-200">

              {/* Header */}
              <div className="flex-none p-5 border-b border-gray-100 bg-gray-50/50">
                <div className="flex items-start justify-between">
                  <div>
                    <h3 className="text-base font-bold text-slate-900 flex items-center gap-2">
                      <span className="flex h-6 w-6 items-center justify-center rounded-full bg-blue-100/50 text-blue-600">
                        <Monitor size={14} />
                      </span>
                      Centre accessibilité
                    </h3>
                    <p className="mt-1 text-xs text-slate-500 max-w-[280px]">
                      Optimisez l'accessibilité de vos contenus pour le référencement et les lecteurs d'écran.
                    </p>
                  </div>
                  <button
                    className="rounded-full p-1.5 text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors"
                    onClick={() => setShowAltPanel(false)}
                  >
                    <XIcon size={18} />
                  </button>
                </div>
              </div>

              {/* Body */}
              <div className="flex-1 overflow-y-auto p-4 space-y-6 bg-slate-50/30">
                {altSummary.total === 0 && altSummary.mediaIssues.length === 0 ? (
                  <div className="flex flex-col items-center justify-center py-12 text-center">
                    <div className="h-12 w-12 rounded-full bg-green-100 text-green-600 flex items-center justify-center mb-3 text-xl">
                      ✓
                    </div>
                    <h4 className="text-sm font-semibold text-slate-900">Tout est parfait !</h4>
                    <p className="text-xs text-slate-500 mt-1">Tous vos médias ont une description.</p>
                  </div>
                ) : (
                  altSummary.per.map(entry => (
                    <div key={entry.id} className="space-y-3">
                      <div className="flex items-center justify-between sticky top-0 md:static z-10 bg-slate-50/95 py-2 backdrop-blur-sm">
                        <div className="flex items-center gap-2">
                          <span className="text-xs font-bold uppercase tracking-wider text-slate-500">{entry.label}</span>
                          <span className="text-[10px] bg-red-100 text-red-700 px-1.5 py-0.5 rounded-full font-bold">
                            {entry.count} manquants
                          </span>
                        </div>
                        <button
                          type="button"
                          className="text-[10px] font-semibold text-blue-600 hover:underline flex items-center gap-1"
                          onClick={() => goToBlock(entry.id, entry.index)}
                        >
                          Localiser <span aria-hidden>→</span>
                        </button>
                      </div>

                      {entry.itemIds.map(itemId => {
                        const issue = altSummary.items[itemId];
                        if (!issue) return null;
                        return (
                          <div key={itemId} className="group relative rounded-xl border border-gray-200 bg-white p-3 shadow-sm transition-shadow hover:shadow-md hover:border-gray-300">
                            <div className="flex gap-3">
                              {/* Thumbnail */}
                              {issue.src && (
                                <div className="shrink-0">
                                  <div className="h-16 w-16 overflow-hidden rounded-lg border border-gray-100 bg-gray-50">
                                    <img src={issue.src} alt="" className="h-full w-full object-cover" />
                                  </div>
                                </div>
                              )}

                              {/* Inputs */}
                              <div className="flex-1 min-w-0">
                                <div className="mb-2 flex items-center justify-between">
                                  <span className="text-[10px] font-medium text-slate-400 font-mono truncate max-w-[120px]" title={issue.location}>
                                    {issue.location}
                                  </span>
                                </div>

                                <textarea
                                  value={issue.altText}
                                  onChange={e => updateAltTextForIssue(itemId, e.target.value)}
                                  placeholder="Décrivez l’image..."
                                  className="w-full resize-y rounded-lg border-gray-200 bg-gray-50 px-3 py-2 text-xs text-slate-800 placeholder:text-slate-400 focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 min-h-[60px]"
                                />

                                <div className="mt-2 flex items-center justify-between">
                                  <label className="flex items-center gap-1.5 cursor-pointer group/toggle">
                                    <input
                                      type="checkbox"
                                      checked={!!issue.decorative}
                                      onChange={e => {
                                        const isImage = issue.kind === 'image';
                                        const targetId = issue.targetBlockId;
                                        if (!targetId) return;

                                        updateBlockById(targetId, current => {
                                          if (isImage && current.type === 'image') return { ...current, decorative: e.target.checked, altText: '' };
                                          if (!isImage && current.type === 'gallery') {
                                            const g = current as GalleryBlock;
                                            const newImages = g.images?.map((img, idx) => {
                                              const match = (issue.imageId && img.id === issue.imageId) || (!issue.imageId && idx === issue.imageIndex);
                                              return match ? { ...img, decorative: e.target.checked, altText: '' } : img;
                                            }) || [];
                                            return { ...g, images: newImages };
                                          }
                                          return current;
                                        });
                                      }}
                                      className="h-3.5 w-3.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500 transition"
                                    />
                                    <span className="text-[11px] text-slate-500 font-medium group-hover/toggle:text-slate-700">Décoratif</span>
                                  </label>

                                  {issue.caption && (
                                    <span className="text-[10px] text-slate-400 italic bg-slate-50 px-1.5 rounded truncate max-w-[100px]" title={issue.caption}>
                                      "{issue.caption}"
                                    </span>
                                  )}
                                </div>
                              </div>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  ))
                )}
              </div>

              {/* Footer */}
              <div className="flex-none p-4 bg-white border-t border-gray-100 flex items-center justify-between gap-3">
                <button
                  onClick={resetGenericAltAll}
                  className="flex-1 rounded-lg border border-gray-200 px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50 hover:text-slate-800 transition-colors"
                >
                  Nettoyer ALT génériques
                </button>
                <button
                  onClick={exportAltCsv}
                  className="flex-1 rounded-lg bg-slate-900 px-3 py-2 text-xs font-bold text-white shadow-sm hover:bg-slate-800 transition-transform hover:-translate-y-0.5 active:translate-y-0"
                >
                  Export CSV
                </button>
              </div>
            </div>
          )}

          {/* Mobile Shield */}
          <div className="flex flex-1 flex-col items-center justify-center p-8 text-center lg:hidden">
            <div className="mb-6 rounded-full bg-slate-100 p-4 ring-1 ring-slate-200">
              <Monitor className="h-8 w-8 text-slate-400" strokeWidth={1.5} />
            </div>
            <h3 className="mb-2 text-lg font-semibold text-slate-900">
              L’éditeur est optimisé pour les grands écrans
            </h3>
            <p className="max-w-xs text-sm text-slate-500">
              Pour garantir la meilleure expérience de personnalisation, veuillez utiliser un ordinateur ou une tablette en mode paysage.
            </p>
          </div>

          <div className={workspaceClassName} style={workspaceStyle}>
            {showPalette && viewMode === 'edit' && (
              <EditorPalette
                placement={isBanner ? 'dock' : 'sidebar'}
                isBanner={isBanner}
                paletteView={paletteView}
                setPaletteView={setPaletteView}
                qualityIndicators={qualityIndicators}
                bannerCoach={bannerCoach}
                bannerInsights={bannerInsights}
                bannerInsightsLoading={bannerInsightsLoading}
                refreshBannerInsights={refreshBannerInsights}
                formatRelativeTime={formatRelativeTime}
                focusSeoInputs={focusSeoInputs}
                paletteQuery={paletteQuery}
                setPaletteQuery={setPaletteQuery}
                paletteSearchInputRef={paletteSearchInputRef}
                blocks={blocks}
                blockTypes={blockTypes}
                blockDescriptions={blockDescriptions}
                selectedIndex={selectedIndex}
                setSelectedIndex={setSelectedIndex}
                goToBlock={goToBlock}
                addBlock={addBlock}
                handleDragStart={handleDragStart}
                bannerDesignWidth={BANNER_DESIGN_WIDTH}
                bannerDesignHeight={BANNER_DESIGN_HEIGHT}
                paletteRef={paletteRef}
                openQuickSectionsFor={() => { }}
                selectedChild={selectedChild}
                setSelectedChild={setSelectedChild}
              />
            )}
            {/* Canvas */}
            <div
              ref={canvasRef}
              className={`${canvasWrapperClasses} ${isBanner ? 'order-1 xl:order-auto xl:col-start-1 xl:row-start-1 xl:row-end-2 xl:self-stretch xl:justify-self-stretch' : ''}`}
              style={canvasWidth && !(isBanner || isPoster) ? { width: canvasWidth } : undefined}
            >
              <main
                ref={mainScrollRef}
                className={`${canvasMainClassName} ${(isFocusMode || viewMode === 'preview') ? '!max-w-none !w-full !px-0' : ''} ${device === 'mobile'
                  ? 'mx-auto my-8 !max-w-[375px] !w-[375px] rounded-[2.5rem] border-[12px] border-slate-800 bg-white shadow-2xl ring-1 ring-slate-900/5'
                  : ''
                  } ease-in-out origin-top`}
                style={{
                  maxWidth: (isFocusMode || viewMode === 'preview') ? '100%' : (device === 'mobile'
                    ? '375px'
                    : isBanner
                      ? bannerDesktopShellWidthCss
                      : desktopMaxWidth),
                  width: (isFocusMode || viewMode === 'preview') ? '100%' : (device === 'mobile'
                    ? '375px'
                    : isBanner
                      ? bannerDesktopShellWidthCss
                      : (isPoster ? `min(100%, ${desktopMaxWidth}px)` : undefined)),
                  minHeight: device === 'mobile' ? '812px' : undefined
                }}
                onDragOver={e => { e.preventDefault(); setIsCanvasDragOver(true); }}
                onDragEnter={e => { e.preventDefault(); setIsCanvasDragOver(true); }}
                onDragLeave={e => { if ((e.target as HTMLElement) === e.currentTarget) setIsCanvasDragOver(false); }}
                onDrop={handleDrop}
              >
                {/* Frame blanche délimitant la zone de personnalisation */}
                <div
                  className={`${canvasFrameClassName} ${device === 'mobile' ? 'rounded-[1.8rem] overflow-hidden' : ''}`}
                  style={(isPoster || isBanner)
                    ? device === 'mobile'
                      ? {
                        height: '100%',
                        width: '100%',
                        overflowY: 'auto',
                        display: 'flex',
                        justifyContent: 'center',
                        paddingTop: '40px',
                        paddingBottom: '40px',
                      }
                      : isBanner
                        ? {
                          minHeight: BANNER_DESIGN_HEIGHT,
                          maxHeight: BANNER_DESIGN_HEIGHT,
                          overflow: 'hidden',
                          width: bannerDesktopShellWidthCss,
                          maxWidth: bannerDesktopShellWidthCss,
                        }
                        : {
                          minHeight: posterDesignHeight,
                          maxHeight: posterDesignHeight,
                          overflowY: 'auto',
                        }
                    : undefined}
                >
                  {isPoster && (
                    <div className="pointer-events-none absolute inset-0 z-10 rounded-[inherit] border border-dashed border-slate-300/60" />
                  )}
                  {/* Contenu du canvas, avec règles optionnelles */}
                  <div
                    ref={canvasContentRef}
                    style={{
                      backgroundColor: theme.backgroundColor || '#ffffff',
                      color: theme.textColor,
                      fontFamily: theme.bodyFont,
                      backgroundImage: viewMode === 'preview'
                        ? (theme.backgroundImageUrl ? `url(${theme.backgroundImageUrl})` : undefined)
                        : (theme.backgroundImageUrl
                          ? `url(${theme.backgroundImageUrl}), linear-gradient(rgba(0,0,0,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.035) 1px, transparent 1px)`
                          : `linear-gradient(rgba(0,0,0,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.035) 1px, transparent 1px)`),
                      backgroundSize: viewMode === 'preview'
                        ? (theme.backgroundImageUrl ? 'cover' : undefined)
                        : (theme.backgroundImageUrl ? 'cover, 24px 24px, 24px 24px' : '24px 24px, 24px 24px'),
                      backgroundPosition: viewMode === 'preview'
                        ? (theme.backgroundImageUrl ? 'center' : undefined)
                        : (theme.backgroundImageUrl ? 'center, 0 0, 0 0' : undefined),
                    }}
                  >

                    <div>
                      {/* Image de couverture */}
                      {theme.coverImageUrl && (
                        <div className="mb-4">
                          <img loading="lazy" src={theme.coverImageUrl} alt="Couverture" className="w-full h-32 object-cover rounded" />
                        </div>
                      )}
                      {!isBanner && (
                        <div className="sticky top-0 z-10 border-b border-gray-200/70 bg-white/80 px-4 py-3 backdrop-blur supports-[backdrop-filter]:bg-white/60">
                          <div className="flex items-center justify-between gap-3">
                            <h3 className="flex items-center gap-2 text-sm font-semibold" style={{ fontFamily: theme.headingFont }}>
                              Canvas
                              {pageKey && (
                                <span className="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] ring-1 bg-gray-50 text-gray-700 ring-gray-200">
                                  {pageKey === 'poster' ? 'Affiche' : pageKey === 'banner' ? 'Bandeau' : 'Profil'}
                                </span>
                              )}
                            </h3>
                            <div className="flex items-center gap-2">
                              <span className="ml-2 text-[11px] px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 ring-1 ring-blue-200">
                                {device === 'mobile'
                                  ? ((isBanner || isPoster) && canvasFormatLabelMobile
                                    ? `Mobile • ${canvasFormatLabelMobile}`
                                    : `Mobile • largeur ${mobilePreviewWidth}px`)
                                  : ((isBanner || isPoster) && canvasFormatLabelDesktop
                                    ? `Desktop • ${canvasFormatLabelDesktop}`
                                    : 'Desktop • largeur max 1200px')}
                              </span>
                              <button
                                onClick={() => setIsFocusMode(p => !p)}
                                className={`ml-1 p-1 rounded transition ${isFocusMode ? 'bg-purple-100 text-purple-700' : 'text-gray-400 hover:text-gray-600'}`}
                                title="Mode Focus (Cinéma)"
                              >
                                <span className="icon-maximize" />
                              </button>
                            </div>
                          </div>
                        </div>
                      )}
                      <div className={`${bannerLeadSectionClass} transition-all duration-500`}>
                        {isBanner && showBannerInfoPill && (
                          <div className="mb-3 flex flex-wrap items-center justify-between gap-2 text-[11px] text-slate-600">
                            <span className="inline-flex items-center gap-2">
                              <span className="inline-flex items-center gap-1 rounded-full border border-slate-800 bg-slate-900 px-2.5 py-1 font-semibold uppercase tracking-[0.18em] text-white">
                                Bandeau
                              </span>
                              <span className="inline-flex items-center gap-1 rounded-full border border-slate-200/80 bg-white/90 px-2.5 py-1 font-medium text-slate-700 shadow-sm">
                                {device === 'mobile'
                                  ? `Mobile • ${canvasFormatLabelMobile}`
                                  : `Desktop • ${canvasFormatLabelDesktop}`}
                              </span>
                            </span>
                          </div>
                        )}
                        {(isBanner || isPoster) && canvasFormatLabelDesktop && canvasFormatLabelMobile && hasDimensionError && (
                          <div className="px-4 space-y-2">
                            <div className="space-y-1 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-[11px] text-red-700">
                              {dimensionErrors.map((error, idx) => (
                                <p key={idx}>{error}</p>
                              ))}
                              <p className="font-medium">
                                Format attendu : {canvasFormatLabelDesktop} (desktop) · {canvasFormatLabelMobile} (mobile).
                              </p>
                            </div>
                          </div>
                        )}
                        {blocks.length === 0 && (
                          <div className="px-3 text-xs text-gray-600 space-y-2">
                            <div>Astuce: glissez un bloc depuis la palette pour commencer.</div>
                            {pageKey === 'poster' && (
                              <div className="flex items-center gap-2 flex-wrap">
                                <button onClick={() => handleAddBlock('oeuvre')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Ajouter un bloc Œuvres</button>
                              </div>
                            )}
                            {pageKey === 'banner' && (
                              <div className="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-2 text-[11px] text-slate-600">
                                <p className="font-semibold text-slate-700">Composez votre bandeau :</p>
                                <p className="mt-1">
                                  Ajoutez une section héro depuis la palette, puis complétez avec une touche narrative
                                  ou un CTA. Activez les guides au besoin pour visualiser la fenêtre mobile.
                                </p>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    </div>
                    {/* Device Mode Indicator - Makes it clear layouts are independent */}

                    {/* Zone de travail (hauteur adaptée pour bandeau) */}
                    {/* Free-Form / Antigravity Mode */}
                    {isFreeForm ? (
                      viewMode === 'preview' ? (
                        <PreviewFrame
                          blocks={effectiveBlocks}
                          width={device === 'mobile' ? mobilePreviewWidth : (isBanner ? BANNER_DESIGN_WIDTH : (canvasWidth || desktopMaxWidth))}
                          height={device === 'mobile' ? (isBanner ? BANNER_DESIGN_HEIGHT_MOBILE : posterDesignHeightMobile) : (isBanner ? BANNER_DESIGN_HEIGHT : isPoster ? posterDesignHeight : undefined)}
                          artist={artistData}
                          artworks={oeuvreOptions}
                          enableAbsolutePositioning={isFreeForm}
                        />
                      ) : (
                        <FreeFormCanvas
                          width={isBanner ? BANNER_DESIGN_WIDTH : (device === 'mobile' ? 390 : desktopMaxWidth)}
                          minHeight={isBanner ? BANNER_DESIGN_HEIGHT : undefined}
                          backgroundColor={theme.backgroundColor}
                          renderBlock={renderPreviewBlock}
                        />
                      )
                    ) : (
                      <DndContext
                        collisionDetection={rectIntersection}
                        sensors={sensors}
                        onDragStart={handleDndKitDragStart}
                        onDragEnd={handleDndKitDragEnd}
                        measuring={{
                          droppable: {
                            strategy: MeasuringStrategy.Always,
                          }
                        }}
                        modifiers={[]} // Removed restrictions as requested
                      >
                        <SortableContext items={desktopLayout} strategy={rectSortingStrategy}>
                          <div
                            className={isBanner ? 'relative' : undefined}
                            style={(isBanner || isPoster)
                              ? device === 'mobile'
                                ? isBanner
                                  ? {
                                    minHeight: BANNER_DESIGN_HEIGHT_MOBILE,
                                    maxHeight: BANNER_DESIGN_HEIGHT_MOBILE,
                                    overflow: 'hidden',
                                  }
                                  : {
                                    minHeight: posterDesignHeightMobile,
                                    maxHeight: posterDesignHeightMobile,
                                    overflowY: 'auto',
                                  }
                                : isBanner
                                  ? {
                                    minHeight: BANNER_DESIGN_HEIGHT,
                                    maxHeight: BANNER_DESIGN_HEIGHT,
                                    overflow: 'hidden',
                                  }
                                  : {
                                    minHeight: posterDesignHeight,
                                    maxHeight: posterDesignHeight,
                                    overflowY: 'auto',
                                  }
                              : { height: '100%', overflowY: 'auto', width: '100%' }}
                          >

                            <div
                              ref={bannerContentRef}
                              className={`relative z-10 ${device === 'mobile'
                                ? 'flex flex-col gap-4 w-full'
                                : (isBanner ? 'space-y-3' : 'space-y-4')
                                }`}
                              role="list"
                            >
                              {desktopLayout.length === 0 ? (
                                <div className="border-2 border-dashed rounded-lg p-8 text-center text-gray-500 bg-gray-50">
                                  <p className="mb-4">
                                    {isBanner
                                      ? 'Commencez avec un bloc de texte ou une image, puis ajoutez un bouton pour orienter vos visiteurs.'
                                      : 'Commencez en ajoutant des blocs.'}
                                  </p>
                                  <div className="flex items-center justify-center gap-2 flex-wrap">
                                    {isBanner ? (
                                      <>
                                        <button onClick={() => handleAddBlock('text')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Texte</button>
                                        <button onClick={() => handleAddBlock('image')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Image</button>
                                        <button onClick={() => handleAddBlock('button')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Bouton</button>
                                        <button onClick={() => handleAddBlock('container')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Section</button>
                                      </>
                                    ) : (
                                      <>
                                        <button onClick={() => handleAddBlock('artistName')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Nom d’artiste</button>
                                        <button onClick={() => handleAddBlock('artistPhoto')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Photo</button>
                                        <button onClick={() => handleAddBlock('artistBio')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Biographie</button>
                                        <button onClick={() => handleAddBlock('oeuvre')} className="px-3 py-1.5 text-sm bg-white border rounded hover:bg-gray-50">Œuvres</button>
                                      </>
                                    )}
                                  </div>
                                </div>
                              ) : (
                                desktopLayout.map((id, idx) => {
                                  const block = blocksData[id];
                                  if (!block) return null;
                                  return <SortableItem key={id} block={block} idx={idx} />;
                                })
                              )}
                            </div>
                          </div>
                        </SortableContext>
                        {mounted && createPortal(
                          <DragOverlay modifiers={[restrictToVerticalAxis]}>
                            {activeDragType ? (
                              <div className="inline-flex items-center px-3 py-2 bg-white/90 shadow-sm rounded-lg ring-1 ring-blue-200 whitespace-nowrap">
                                {(() => { const Icon = iconMap[activeDragType]; return <Icon className="mr-2 text-gray-600" size={18} />; })()}
                                <span className="text-sm text-gray-800 capitalize">{activeDragType}</span>
                              </div>
                            ) : null}
                          </DragOverlay>,
                          document.body
                        )}
                      </DndContext>
                    )}
                  </div>
                </div>{/* fin frame blanche */}
              </main>
            </div>
            {
              isBanner && bannerOverflow > 0 && (
                <div
                  className="order-2 w-full max-w-[1280px] self-center xl:col-start-1 xl:row-start-2 xl:self-stretch xl:justify-self-stretch"
                  style={{ maxWidth: bannerDesktopShellWidthCss, width: '100%' }}
                >
                  <BannerOptimizePanel
                    bannerCoach={bannerCoach}
                    bannerInsights={bannerInsights}
                    bannerInsightsLoading={bannerInsightsLoading}
                    refreshBannerInsights={refreshBannerInsights}
                    formatRelativeTime={formatRelativeTime}
                    bannerCanvasDiagnostics={bannerCanvasDiagnostics}
                  />
                </div>
              )
            }
            {/* Resizer between Canvas and Inspector */}
            {
              inspectorPaneActive && !isBanner && (
                <div
                  onMouseDown={startResizing}
                  className="relative flex-shrink-0 h-full w-3 cursor-col-resize bg-gradient-to-b from-transparent via-gray-300/60 to-transparent transition hover:via-blue-400/50"
                />
              )
            }
            {/* Inspector */}
            {
              inspectorPaneActive && (
                <aside
                  ref={inspectorRef}
                  className={`relative flex h-full w-[300px] flex-shrink-0 flex-col overflow-y-auto rounded-2xl border border-gray-200/70 bg-white/85 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-white/70 scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-gray-100 md:w-[320px] ${isBanner ? 'order-2 xl:order-auto xl:col-start-2 xl:row-start-1 xl:row-end-2 xl:self-stretch' : ''}`}
                >
                  <div ref={inspectorContainerRef} tabIndex={-1} aria-label="Inspecteur" />
                  {selectedChild !== null ? (() => {
                    const { parentId, childId } = selectedChild;
                    const parent = findBlockById(blocks, parentId) as any;
                    if (!parent) {
                      return (
                        <div className="p-4 text-xs text-gray-500">
                          Bloc parent introuvable. Sélectionnez un élément du canevas.
                        </div>
                      );
                    }
                    let childBlock: Block | undefined;
                    if (parent.type === 'container') {
                      const container = parent as ContainerBlock;
                      childBlock = container.children?.find((c: Block) => c.id === childId);
                    } else if (parent.type === 'columns') {
                      const columnsBlock = parent as ColumnBlock;
                      for (const col of (columnsBlock.columns || [])) {
                        childBlock = col?.find((c: Block) => c.id === childId);
                        if (childBlock) break;
                      }
                    }
                    if (!childBlock) {
                      return (
                        <div className="p-4 text-xs text-gray-500">
                          Bloc introuvable. Sélectionnez un élément du canevas.
                        </div>
                      );
                    }
                    const childBlockId = childBlock.id;
                    const childTextCommands = childBlockId ? textCommandHandlersRef.current[childBlockId] : undefined;
                    const updateChild = (updated: Block) => {
                      updateBlockById(childId, () => updated);
                    };
                    return (
                      <BlockInspector
                        block={childBlock}
                        oeuvreOptions={oeuvreOptions}
                        onUpdate={updateChild}
                        onClose={() => setSelectedChild(null)}
                        textCommandApi={childTextCommands}
                        pageKey={pageKey}
                        onConvert={convertBlock}
                      />
                    );
                  })() : selectedIndex !== null ? (
                    (() => {
                      const selectedBlock = blocks[selectedIndex];
                      if (!selectedBlock) {
                        return (
                          <p className="p-4 text-sm text-gray-500">
                            Bloc introuvable. Sélectionnez un élément du canevas.
                          </p>
                        );
                      }
                      const selectedId = selectedBlock.id;
                      const selectedTextCommands = selectedId ? textCommandHandlersRef.current[selectedId] : undefined;
                      return (
                        <BlockInspector
                          block={selectedBlock}
                          oeuvreOptions={oeuvreOptions}
                          onUpdate={b => {
                            // Atmosphere Extraction Hook
                            const isFirstBlock = selectedIndex === 0;
                            // Determine previous block state
                            const prev = blocks[selectedIndex];

                            // Check for Container/Text (Background Image)
                            if (isFirstBlock && ((b.type === 'container') || (b.type === 'text'))) {
                              const prevBg = prev.style?.backgroundImageUrl;
                              const nextBg = b.style?.backgroundImageUrl;
                              if (nextBg && nextBg !== prevBg && typeof nextBg === 'string') {
                                // Image changed, trigger analysis
                                extractAtmosphere(nextBg).then((color: string | null) => {
                                  if (color) {
                                    const contrastText = getTextColorForBackground(color);
                                    addToast(
                                      `Ambiance détectée : ${color}`,
                                      'info',
                                      8000,
                                      {
                                        label: 'Appliquer l’ambiance',
                                        onClick: () => {
                                          setTheme(t => ({ ...t, backgroundColor: color, textColor: contrastText }));
                                          addToast('Ambiance appliquée !', 'success');
                                        }
                                      }
                                    );
                                  }
                                });
                              }
                            }

                            // Also check for 'image' block type if it's the first block serving as hero
                            if (isFirstBlock && ((b as any).type === 'image' || (b as any).type === 'artistPhoto')) {
                              const prevSrc = (prev as any)?.src;
                              const nextSrc = (b as any)?.src;
                              if (nextSrc && nextSrc !== prevSrc && typeof nextSrc === 'string') {
                                extractAtmosphere(nextSrc).then((color: string | null) => {
                                  if (color) {
                                    const contrastText = getTextColorForBackground(color);
                                    addToast(
                                      'Ambiance détectée',
                                      'info',
                                      8000,
                                      {
                                        label: 'Appliquer',
                                        onClick: () => {
                                          setTheme(t => ({ ...t, backgroundColor: color, textColor: contrastText }));
                                          addToast('Ambiance appliquée !', 'success');
                                        }
                                      }
                                    );
                                  }
                                });
                              }
                            }

                            updateBlockById(selectedId, () => b);
                          }}
                          setSelectedChild={setSelectedChild}
                          onClose={() => setSelectedIndex(null)}
                          textCommandApi={selectedTextCommands}
                          pageKey={pageKey}
                          onDelete={(id) => {
                            if (selectedIndex !== null) {
                              removeBlock(selectedIndex);
                              setSelectedIndex(null);
                            }
                          }}
                          onConvert={convertBlock}
                        />
                      );
                    })()
                  ) : (
                    <p className="px-4 py-6 text-sm text-gray-500">Sélectionnez un bloc à inspecter</p>
                  )}
                </aside>
              )
            }
            {
              viewMode === 'theme' && showThemeModal && (
                <div className="fixed inset-0 z-[60] flex items-center justify-center px-4 py-8">
                  <div
                    className="absolute inset-0 bg-slate-900/60"
                    onClick={closeThemeModal}
                    aria-hidden="true"
                  />
                  <div
                    ref={themeContainerRef}
                    tabIndex={-1}
                    role="dialog"
                    aria-modal="true"
                    aria-label="Paramétrage du thème"
                    className="relative z-10 w-full max-w-5xl focus:outline-none"
                  >
                    {/* <ThemeInspector
                  theme={theme}
                  meta={meta}
                  artistName={artistData?.name}
                  artist={artistData}
                  blocks={blocks}
                  pageKey={currentPage}
                  settings={bannerSettings}
                  onChangeTheme={t => setTheme(t)}
                  onChangeMeta={m => setMeta(m)}
                  onChangeSettings={next => {
                    if (Object.prototype.hasOwnProperty.call(next, 'applyThemeToHome')) {
                      setApplyThemeToHome(next.applyThemeToHome === true);
                    }
                  }}
                  onClose={closeThemeModal}
                /> */}
                  </div>
                </div>
              )
            }

            {showTemplateSelector && (
              <PageTemplateSelector
                onSelect={handleSelectTemplate}
                onClose={() => setShowTemplateSelector(false)}
              />
            )}

            {/* Bouton Tutoriel flottant */}
            <button
              onClick={() => { setTutorialStep(0); setShowTutorial(true); }}
              className="fixed bottom-5 right-5 z-50 w-12 h-12 rounded-full bg-purple-600 hover:bg-purple-700 text-white shadow-lg flex items-center justify-center text-xl"
              title="Tutoriel"
              aria-label="Tutoriel"
            >?
            </button>

          </div >

          {/* Tutoriel: infobulle étape par étape */}
          {
            showTutorial && (() => {
              const steps = [
                { ref: paletteRef, title: 'Palette', text: 'Glissez des blocs pour composer votre page.' },
                { ref: (canvasRef as any), title: 'Canvas', text: 'Zone d’édition: déposez et réorganisez vos blocs.' },
                { ref: inspectorRef, title: 'Inspecteur', text: 'Ajustez contenu et style du bloc sélectionné.' },
                { ref: modeRef, title: 'Modes', text: 'Basculez entre Édition / Thème / Aperçu.' },
                { ref: presetRef, title: 'Presets', text: 'Appliquez une mise en page prédéfinie.' },
                { ref: saveRef, title: 'Enregistrer', text: 'Sauvegarde votre brouillon (non public).' },
                { ref: publishRef, title: 'Publier', text: 'Met en ligne votre page publique.' },
              ];
              const current = Math.max(0, Math.min(tutorialStep, steps.length - 1));
              const step = steps[current];
              const el = (step.ref && (step.ref as any).current) as HTMLElement | null;
              const r = el ? el.getBoundingClientRect() : null;
              const bubbleWidth = 320; const bubbleHeight = 140;
              let top = 100, left = 100; let below = true;
              if (r) {
                below = r.bottom + 12 + bubbleHeight <= window.innerHeight;
                top = below ? r.bottom + 12 : Math.max(12, r.top - 12 - bubbleHeight);
                left = Math.min(Math.max(12, r.left), window.innerWidth - bubbleWidth - 12);
              }
              return (
                <>
                  <div className="fixed inset-0 bg-black/50 z-40" onClick={(e) => { e.stopPropagation(); }} />
                  {r && (
                    <div
                      className={"fixed z-50 ring-4 ring-purple-500 rounded-md pointer-events-none transition-opacity duration-150 " + (tourAnim ? "opacity-100" : "opacity-0")}
                      style={{ top: r.top - 6, left: r.left - 6, width: r.width + 12, height: r.height + 12 }}
                    />
                  )}
                  <div className={"fixed z-50 w-[320px] max-w-[92vw] bg-white border shadow-xl rounded-lg p-4 transition-all duration-150 ease-out " + (tourAnim ? "opacity-100 translate-y-0" : "opacity-0 translate-y-2")} style={{ top, left, position: "fixed" }}>
                    {/* Flèche */}
                    <div className={below ? "absolute -top-2 left-6 w-4 h-4 bg-white rotate-45 shadow-md border-l border-t border-gray-200" : "absolute -bottom-2 left-6 w-4 h-4 bg-white rotate-45 shadow-md border-r border-b border-gray-200"}></div>
                    <div className="flex items-start justify-between gap-3">
                      <div>
                        <div className="font-semibold text-sm mb-1">{step.title}</div>
                        <div className="text-sm text-gray-700 leading-relaxed">{step.text}</div>
                      </div>
                    </div>
                    <div className="mt-3 flex items-center justify-between">
                      <button className="px-2 py-1 text-sm rounded bg-gray-100 hover:bg-gray-200" onClick={(e) => { e.stopPropagation(); setTutorialStep(s => Math.max(0, s - 1)); }} disabled={current === 0}>Précédent</button>
                      <div className="text-xs text-gray-500">{current + 1}/{steps.length}</div>
                      <button className="px-3 py-1 text-sm rounded bg-blue-600 text-white hover:bg-blue-700" onClick={(e) => { e.stopPropagation(); if (current < steps.length - 1) setTutorialStep(current + 1); else endTour(); }}>{current < steps.length - 1 ? 'Suivant' : 'Terminer'}</button>
                    </div>
                    <div className="mt-2 text-xs text-gray-400">Astuce : appuyez sur Échap pour fermer</div>
                  </div>
                </>
              );
            })()
          }

          <input ref={fileInputRef} type="file" accept="application/json,.json" className="hidden" onChange={handleImportFile} />


        </div >
      </EditorStateContext.Provider>
    </EditorActionsContext.Provider>
  );
}
