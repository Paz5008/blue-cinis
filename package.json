{
  "name": "blue-cinis",
  "version": "1.0.0",
  "private": true,
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "patch-package",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.config.mts run",
    "test:critical": "vitest --config vitest.config.mts run test/api.payments.webhook.test.ts",
    "lint:css": "stylelint \"**/*.{css,scss}\" --fix",
    "seed": "node scripts/seed.js",
    "test-email": "node scripts/test-email.js",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "health": "node scripts/health-check.js",
    "diag:db": "bash scripts/db-diag.sh",
    "migrate:artistpages": "ts-node scripts/migrate-legacy-to-artistpage.ts",
    "db:dev": "node scripts/prisma-shadow.js migrate dev",
    "ci:health": "ALLOW_HEALTH_ISSUES=1 BASE_URL=http://localhost:3000 node scripts/health-check.js",
    "inspector:gen": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/generate-inspector-registry.ts",
    "inspector:enrich": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/enrich-inspector-registry.ts",
    "test:e2e": "playwright test",
    "cleanup:reservations": "ts-node scripts/cleanup-reservations.ts",
    "media:migrate": "ts-node scripts/migrate-uploads-to-cloudinary.ts",
    "media:rewrite": "ts-node scripts/replace-uploads-urls.ts",
    "media:rewrite:proxy": "USE_PROXY=1 ts-node scripts/replace-uploads-urls.ts",
    "media:rewrite:dry": "DRY_RUN=1 ts-node scripts/replace-uploads-urls.ts",
    "media:switch": "ts-node scripts/sitewide-cloudinary-switch.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:coverage": "vitest --config vitest.config.mts run --coverage",
    "build:mock": "PRISMA_MOCK=1 next build",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:migrate:v2": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/migrate-to-v2.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@formkit/auto-animate": "^0.8.2",
    "@google/model-viewer": "^4.1.0",
    "@prisma/client": "^6.13.0",
    "@react-email/components": "^0.0.22",
    "@react-email/render": "^0.0.17",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^8.38.0",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.0",
    "@types/openseadragon": "^5.0.1",
    "@types/three": "^0.182.0",
    "@upstash/ratelimit": "^1.1.3",
    "@upstash/redis": "^1.34.3",
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "fast-average-color": "^9.5.0",
    "framer-motion": "^12.6.2",
    "imagesloaded": "^5.0.0",
    "lamina": "^1.2.2",
    "lenis": "^1.3.16",
    "lucide-react": "^0.487.0",
    "maath": "^0.10.8",
    "mutative": "^1.3.0",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^6.10.0",
    "openseadragon": "^5.0.1",
    "pino": "^9.4.0",
    "react": "^18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.5.2",
    "react-quill": "^2.0.0",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.33.4",
    "stripe": "^16.0.0",
    "tailwind-merge": "^3.2.0",
    "three": "^0.182.0",
    "tunnel-rat": "^0.1.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.2",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.8",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.20",
    "daisyui": "^5.0.50",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "happy-dom": "^20.0.11",
    "i": "^0.3.7",
    "npm": "^11.2.0",
    "patch-package": "^8.0.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^6.13.0",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^29.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^3.3.3",
    "ts-node": "^10.9.1",
    "typescript": "5.7.3",
    "vite": "^5.4.8",
    "vitest": "^1.6.0"
  }
}
